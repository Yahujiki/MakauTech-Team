<!-- ═══ CULTURAL CALENDAR — when Sibu comes alive ═══════════════ -->
<section class="lp-section">
    <div class="lp-container">
        <div class="lp-section-head">
            <div>
                <span class="lp-section-kicker">📅 Cultural calendar</span>
                <h2 class="lp-section-h2">When Sibu comes alive</h2>
                <p class="lp-section-sub">Time your visit to a festival — Sibu becomes a different city when the lanterns go up and the drums start.</p>
            </div>
        </div>
        <div class="lp-cal-grid">
            <article class="lp-cal-card lp-cal-card--festival">
                <div class="lp-cal-date">
                    <span class="lp-cal-day">18-27</span>
                    <span class="lp-cal-month">JUL</span>
                </div>
                <div class="lp-cal-body">
                    <span class="lp-cal-tag">Festival</span>
                    <h3 class="lp-cal-title">Borneo Cultural Festival</h3>
                    <p class="lp-cal-loc">📍 Sibu Town Square</p>
                    <p class="lp-cal-desc">Ten days of Iban dance, Foochow opera, Malay pantun, food stalls, and fireworks. The biggest cultural event of the Sibu calendar.</p>
                </div>
            </article>
            <article class="lp-cal-card lp-cal-card--gawai">
                <div class="lp-cal-date">
                    <span class="lp-cal-day">1-2</span>
                    <span class="lp-cal-month">JUN</span>
                </div>
                <div class="lp-cal-body">
                    <span class="lp-cal-tag">Dayak holiday</span>
                    <h3 class="lp-cal-title">Hari Gawai</h3>
                    <p class="lp-cal-loc">📍 Iban longhouses around Sibu</p>
                    <p class="lp-cal-desc">Harvest festival of the Dayak. Visit a longhouse, share tuak rice wine, watch ngajat dance. Open invitations are common — go with a local.</p>
                </div>
            </article>
            <article class="lp-cal-card lp-cal-card--moon">
                <div class="lp-cal-date">
                    <span class="lp-cal-day">17</span>
                    <span class="lp-cal-month">SEP</span>
                </div>
                <div class="lp-cal-body">
                    <span class="lp-cal-tag">Foochow heritage</span>
                    <h3 class="lp-cal-title">Mooncake Festival</h3>
                    <p class="lp-cal-loc">📍 Tua Pek Kong Temple</p>
                    <p class="lp-cal-desc">Lanterns light the temple courtyard, kids parade with paper lions, stalls stack mooncakes higher than your head. The most photogenic night in Sibu.</p>
                </div>
            </article>
            <article class="lp-cal-card lp-cal-card--market">
                <div class="lp-cal-date">
                    <span class="lp-cal-day">FRI</span>
                    <span class="lp-cal-month">WEEKLY</span>
                </div>
                <div class="lp-cal-body">
                    <span class="lp-cal-tag">Recurring</span>
                    <h3 class="lp-cal-title">Tamu Sibu Night Market</h3>
                    <p class="lp-cal-loc">📍 Sibu Central · 5pm – late</p>
                    <p class="lp-cal-desc">Every Friday — Foochow snacks, jungle produce, stalls run by Iban traders down from the longhouses. Bring small notes and an empty stomach.</p>
                </div>
            </article>
        </div>
    </div>
</section>
<style>
.lp-cal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
}
.lp-cal-card {
    display: flex;
    background: #fff;
    border-radius: 18px;
    padding: 20px;
    gap: 18px;
    border: 1px solid rgba(15,23,42,0.07);
    box-shadow: 0 4px 18px rgba(15,23,42,0.05);
