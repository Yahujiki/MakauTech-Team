<!-- ═══ LATEST UPDATES ════════════════════════════════════════ -->
@{
    var latestUpdates = (ViewBag.LatestUpdates as List<MakauTech.Models.Update>) ?? new List<MakauTech.Models.Update>();
}
@if (latestUpdates.Any())
{
    @functions {
        string LpCatColor(string? c) => (c ?? "").ToLower() switch
        {
            "politics" or "civic"           => "#a855f7",
            "infrastructure" or "aviation"  => "#3b82f6",
            "festival" or "heritage"        => "#f59e0b",
            "culture"                       => "#dc2626",
            "tourism" or "community"        => "#10b981",
            "environment"                   => "#22c55e",
            "health"                        => "#ec4899",
            _                               => "#64748b",
        };
    }
<section class="lp-section lp-section--alt">
    <div class="lp-container">
        <div class="lp-section-head">
            <div>
                <span class="lp-section-kicker">📢 Sibu Daily</span>
                <h2 class="lp-section-h2">Latest from Sibu</h2>
                <p class="lp-section-sub" style="margin-top:0.4rem;">News, festivals, infrastructure — every story sourced from a Sarawak publication.</p>
            </div>
            <a href="@Url.Action("Updates","Home")" class="mk-btn-outline-dark">All news →</a>
        </div>
        <div class="lp-news-grid">
            @foreach (var u in latestUpdates)
            {
                var color = LpCatColor(u.Category);
                <a href="@Url.Action("UpdateDetail","Home",new{id=u.Id})"
                   class="lp-news-card mk-fade-in"
                   aria-label="Read @u.Title">
                    <div class="lp-news-thumb">
                        @if (!string.IsNullOrEmpty(u.ImageUrl))
                        {
                            <img src="@u.ImageUrl" alt="@u.Title" loading="lazy" />
                        }
                        else
                        {
                            <span class="lp-news-thumb-fallback" aria-hidden="true">📰</span>
                        }
                        @if (!string.IsNullOrEmpty(u.Category))
                        {
                            <span class="lp-news-cat" style="background:@(color); color:#fff;">@u.Category.ToUpper()</span>
                        }
                    </div>
                    <div class="lp-news-body">
                        <div class="lp-news-meta">
                            <span class="lp-news-date">@u.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</span>
                        </div>
                        <h3 class="lp-news-title">@u.Title</h3>
                        @if (!string.IsNullOrEmpty(u.Summary))
                        {
                            <p class="lp-news-sum">@(u.Summary.Length > 110 ? u.Summary[..110] + "…" : u.Summary)</p>
                        }
                        <div class="lp-news-foot">
                            <span class="lp-news-source">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                    <polyline points="15 3 21 3 21 9"/>
                                    <line x1="10" y1="14" x2="21" y2="3"/>
                                </svg>
                                @u.AuthorName
                            </span>
                            <span class="lp-news-arrow">→</span>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
</section>
<style>
