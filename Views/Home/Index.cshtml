<!-- ═══ FEATURED PLACES ════════════════════════════════════════ -->
@if (Model.FeaturedPlaces.Any())
{
<section class="lp-section lp-section--alt">
    <div class="lp-container">
        <div class="lp-section-head">
            <div>
                <span class="lp-section-kicker">Featured spots</span>
                <h2 class="lp-section-h2">Most-visited this week</h2>
            </div>
            <a href="@Url.Action("Explore","Home")" class="mk-btn-outline-dark">See all places →</a>
        </div>
        <div class="mk-grid-3">
            @foreach (var p in Model.FeaturedPlaces.Take(6))
            {
                var likeCount = Model.LikeCounts.ContainsKey(p.Id) ? Model.LikeCounts[p.Id] : 0;
                <a href="@Url.Action("Detail","Place",new{id=p.Id})" class="mk-place-card mk-fade-in">
                    <div class="mk-place-card-img-wrap">
                        <img src="@PlaceImageUrl.Resolve(Url, p.ImageUrl)"
                             alt="@p.Name in @p.Location"
                             loading="lazy"
                             onerror="this.onerror=null;this.src='@ph'" />
                        @if (p.Category != null)
                        {
                            <span class="mk-place-card-cat">@p.Category.Icon @p.Category.Name</span>
                        }
                    </div>
                    <div class="mk-place-card-body">
                        <div class="mk-place-card-name">@p.Name</div>
                        <div class="mk-place-card-loc">📍 @p.Location</div>
                        <div class="mk-place-card-meta">
                            @if (p.Rating > 0) { <span>⭐ <b>@p.Rating.ToString("F1")</b></span> }
                            @if (p.VisitCount > 0) { <span>👥 <b>@p.VisitCount</b> visits</span> }
                            @if (likeCount > 0) { <span>❤️ <b>@likeCount</b></span> }
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
</section>
}

<!-- ═══ TOP EXPLORERS ══════════════════════════════════════════ -->
@if (Model.TopThree.Any())
{
<section class="lp-section">
    <div class="lp-container">
        <div class="lp-section-head">
            <div>
                <span class="lp-section-kicker">Leaderboard</span>
                <h2 class="lp-section-h2">Top explorers</h2>
            </div>
            <a href="@Url.Action("Leaderboard","Home")" class="mk-btn-outline-dark">Full leaderboard →</a>
        </div>
        <div class="lp-podium">
            @for (var i = 0; i < Model.TopThree.Count && i < 3; i++)
            {
                var u = Model.TopThree[i];
                <div class="lp-podium-card mk-fade-in" data-rank="@(i+1)">
                    <div class="lp-podium-rank">Rank #@(i+1)</div>
                    <div class="lp-podium-medal" aria-hidden="true">@(i == 0 ? "🥇" : i == 1 ? "🥈" : "🥉")</div>
                    <div class="lp-podium-name">@u.Name</div>
                    <div class="lp-podium-pts"><strong>@u.Points</strong> pts</div>
                </div>
            }
        </div>
    </div>
</section>
}

<!-- ═══ QUOTE BREAK 2 — Night Market ══════════════════════════ -->
<div class="lp-quote-break" style="background-image:url('/Images/sibu-night-market.jpg');" aria-hidden="true">
    <div class="lp-quote-break-overlay"></div>
    <div class="lp-quote-break-body">
        <span class="lp-quote-tag">Sibu Night Market</span>
        <p class="lp-quote-text">"Every street corner hides a dish worth travelling&nbsp;for."</p>
        <p class="lp-quote-attr">Eat &nbsp;·&nbsp; Explore &nbsp;·&nbsp; Earn points</p>
    </div>
</div>

<!-- ═══ GAMES PROMO — dark editorial ══════════════════════════ -->
<section class="lp-games">
    <div class="lp-games-inner">
        <div>
            <div class="lp-games-eyebrow">🎮 Play to earn</div>
            <h2 class="lp-games-h2">5 Sibu<br /><em>mini-games</em></h2>
            <p class="lp-games-sub">
                Catch Foochow dishes, prep kitchen orders, sprint past obstacles,
                flip memory tiles, answer trivia. Every win earns points and badges
                — compete on the global leaderboard.
            </p>
            <a href="@Url.Action("Games","Home")" class="mk-btn mk-btn-primary" style="font-size:16px;padding:14px 30px;">
                Open games hub →
            </a>
        </div>
        <div>
            <div class="lp-games-tiles" aria-hidden="true">
                <div class="lp-games-tile">🍜</div>
                <div class="lp-games-tile">🍳</div>
                <div class="lp-games-tile">🧠</div>
                <div class="lp-games-tile">🏃</div>
                <div class="lp-games-tile">🎯</div>
                <div class="lp-games-tile" style="font-size:28px;color:rgba(255,255,255,0.22);font-weight:700;font-family:var(--mk-font-display);">+more</div>
            </div>
        </div>
    </div>
</section>

@if (loggedIn)
{
<!-- ═══ QUICK ACTIONS ══════════════════════════════════════════ -->
<section class="lp-section lp-section--alt">
    <div class="lp-container">
        <div class="lp-section-head">
            <div>
                <span class="lp-section-kicker">Welcome back@(string.IsNullOrEmpty(userName) ? "" : ", " + userName)</span>
                <h2 class="lp-section-h2">Quick actions</h2>
            </div>
        </div>
        <div class="lp-quick-grid">
            <a href="@Url.Action("Map","Home")" class="lp-quick-card mk-fade-in">
                <div class="lp-quick-icon" aria-hidden="true">🗺️</div>
                <div class="lp-quick-title">Live Map</div>
                <div class="lp-quick-desc">All Sibu spots, one screen.</div>
            </a>
            <a href="@Url.Action("Achievements","Home")" class="lp-quick-card mk-fade-in mk-fade-in-1">
                <div class="lp-quick-icon" aria-hidden="true">🏆</div>
                <div class="lp-quick-title">Badges</div>
                <div class="lp-quick-desc">Unlock 8 achievements.</div>
            </a>
            <a href="@Url.Action("Profile","Home")" class="lp-quick-card mk-fade-in mk-fade-in-2">
                <div class="lp-quick-icon" aria-hidden="true">👤</div>
                <div class="lp-quick-title">Profile</div>
                <div class="lp-quick-desc">Your stats &amp; visits.</div>
            </a>
            <a href="@Url.Action("Architecture","Home")" class="lp-quick-card mk-fade-in mk-fade-in-3">
                <div class="lp-quick-icon" aria-hidden="true">🏛️</div>
                <div class="lp-quick-title">Architecture</div>
                <div class="lp-quick-desc">ERD, OOP, system design.</div>
            </a>
        </div>
    </div>
</section>
}

@section Scripts {
<script>
(function () {
    'use strict';
    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var isMobile = /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent);

    /* ── Scroll-reveal ── */
    var reveals = Array.prototype.slice.call(document.querySelectorAll('.mk-fade-in'));
    if (reveals.length && 'IntersectionObserver' in window) {
        var obs = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
                if (e.isIntersecting) {
                    e.target.style.opacity  = '1';
                    e.target.style.transform = 'none';
                    obs.unobserve(e.target);
                }
            });
        }, { threshold: 0.10, rootMargin: '0px 0px -40px 0px' });

        reveals.forEach(function (el) {
            var delay = 0;
            if (el.classList.contains('mk-fade-in-1')) delay = 0.12;
            else if (el.classList.contains('mk-fade-in-2')) delay = 0.24;
            else if (el.classList.contains('mk-fade-in-3')) delay = 0.36;
            el.style.opacity    = '0';
            el.style.transform  = 'translateY(24px)';
            el.style.transition = 'opacity 0.65s ease ' + delay + 's, transform 0.65s ease ' + delay + 's';
            obs.observe(el);
        });
    }

    /* ── Parallax on quote-break panels ── */
    if (isMobile || prefersReduced) return;
    var breaks = Array.prototype.slice.call(document.querySelectorAll('.lp-quote-break'));
    if (!breaks.length) return;
    function tickParallax() {
        var vh = window.innerHeight;
        breaks.forEach(function (el) {
            var r = el.getBoundingClientRect();
            if (r.bottom < -80 || r.top > vh + 80) return;
            var offset = ((r.top + r.height / 2) - vh / 2) * 0.16;
            el.style.backgroundPositionY = 'calc(50% + ' + offset.toFixed(1) + 'px)';
        });
    }
    window.addEventListener('scroll', tickParallax, { passive: true });
    tickParallax();
}());
</script>
}
