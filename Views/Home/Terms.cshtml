@{
    ViewData["Title"] = "Terms of Service";
}

@section Styles {
<style>
    body { background: #030d06 !important; }
    .main-content { background: #030d06; }

    /* ============ LAYOUT ============ */
    .lg-page {
        max-width: 1280px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
        color: #e5e7eb;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, sans-serif;
    }

    /* ============ HEADER ============ */
    .lg-header {
        background: linear-gradient(135deg, #052e1a, #0a3d24 50%, #082314);
        border: 1px solid rgba(16,185,129,0.18);
        border-radius: 20px;
        padding: 2rem 2.25rem;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }
    .lg-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 70% 80% at 100% 0%, rgba(16,185,129,0.18) 0%, transparent 70%);
        pointer-events: none;
    }
    .lg-header-inner { position: relative; z-index: 1; }
    .lg-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(16,185,129,0.12);
        border: 1px solid rgba(16,185,129,0.32);
        color: #6ee7b7;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        padding: 0.3rem 0.85rem;
        border-radius: 999px;
        margin-bottom: 1rem;
    }
    .lg-title {
        font-size: clamp(1.85rem, 4vw, 2.7rem);
        font-weight: 800;
        letter-spacing: -0.025em;
        color: #ffffff;
        margin: 0 0 0.5rem;
        line-height: 1.1;
    }
    .lg-subtitle {
        color: rgba(255,255,255,0.65);
        font-size: 0.95rem;
        margin: 0;
        line-height: 1.5;
    }
    .lg-meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        margin-top: 1.25rem;
        padding-top: 1.25rem;
        border-top: 1px solid rgba(255,255,255,0.08);
        font-size: 0.82rem;
        color: rgba(255,255,255,0.55);
    }
    .lg-meta-item strong { color: #6ee7b7; font-weight: 700; }
    .lg-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1rem;
        flex-wrap: wrap;
    }
    .lg-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 1.1rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.85rem;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,0.18);
        background: rgba(255,255,255,0.06);
        color: #ffffff;
        cursor: pointer;
        transition: all 0.18s;
    }
    .lg-btn:hover { background: rgba(16,185,129,0.18); border-color: rgba(16,185,129,0.4); color: #6ee7b7; }
    .lg-btn--primary {
        background: linear-gradient(135deg,#10b981,#059669);
        border-color: transparent;
        color: #ffffff;
    }
    .lg-btn--primary:hover { filter: brightness(1.1); }

    /* ============ TWO-COLUMN BODY ============ */
    .lg-body {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 2rem;
        align-items: start;
    }
    @@media (max-width: 980px) {
        .lg-body { grid-template-columns: 1fr; }
        .lg-toc { position: static !important; }
    }

    /* ============ TABLE OF CONTENTS ============ */
    .lg-toc {
        position: sticky;
        top: 1.5rem;
        background: #0a1812;
        border: 1px solid rgba(16,185,129,0.15);
        border-radius: 16px;
        padding: 1.25rem;
        font-size: 0.9rem;
    }
    .lg-toc-title {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #6ee7b7;
        margin: 0 0 0.85rem;
    }
    .lg-toc ol {
        list-style: none;
        margin: 0;
        padding: 0;
        counter-reset: toc;
    }
    .lg-toc li {
        counter-increment: toc;
        margin: 0;
    }
    .lg-toc a {
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
        padding: 0.5rem 0.6rem;
        border-radius: 8px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        line-height: 1.35;
        transition: all 0.15s;
    }
    .lg-toc a::before {
        content: counter(toc, decimal-leading-zero);
        font-size: 0.7rem;
        font-weight: 700;
        color: rgba(110,231,183,0.7);
        flex-shrink: 0;
    }
    .lg-toc a:hover { background: rgba(16,185,129,0.1); color: #ffffff; }
    .lg-toc a.is-active { background: rgba(16,185,129,0.15); color: #6ee7b7; font-weight: 700; }

    /* ============ MAIN CONTENT ============ */
    .lg-content {
        background: #0a1812;
        border: 1px solid rgba(16,185,129,0.12);
        border-radius: 16px;
        padding: 2.5rem 2.75rem 3rem;
    }
    .lg-section { margin-bottom: 2.25rem; scroll-margin-top: 1.5rem; }
    .lg-section:last-child { margin-bottom: 0; }
    .lg-section-num {
        display: inline-block;
        background: rgba(16,185,129,0.12);
        color: #6ee7b7;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        padding: 0.2rem 0.6rem;
        border-radius: 6px;
        margin-bottom: 0.6rem;
    }
    .lg-h2 {
        font-size: 1.35rem;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: -0.015em;
        margin: 0 0 1rem;
        line-height: 1.25;
    }
    .lg-content p {
        color: rgba(255,255,255,0.75);
        line-height: 1.7;
        font-size: 0.95rem;
        margin: 0 0 0.85rem;
    }
    .lg-content p:last-child { margin-bottom: 0; }
    .lg-content ul {
        margin: 0.5rem 0 1rem;
        padding-left: 1.2rem;
        color: rgba(255,255,255,0.75);
    }
    .lg-content li { line-height: 1.7; margin-bottom: 0.35rem; }
    .lg-content strong { color: #ffffff; font-weight: 700; }
    .lg-content a { color: #6ee7b7; text-decoration: none; border-bottom: 1px solid rgba(110,231,183,0.4); }
    .lg-content a:hover { border-bottom-color: #6ee7b7; }
    .lg-divider {
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(16,185,129,0.25), transparent);
        margin: 2rem 0;
        border: 0;
    }

    /* Callout boxes */
    .lg-callout {
        background: rgba(16,185,129,0.06);
        border-left: 3px solid #10b981;
        padding: 0.9rem 1.1rem;
        border-radius: 0 10px 10px 0;
        margin: 0.85rem 0;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.78);
    }
    .lg-callout--warn {
        background: rgba(245,158,11,0.06);
        border-left-color: #f59e0b;
    }
    .lg-callout strong { display: block; margin-bottom: 0.25rem; color: #ffffff; }

    /* Print styles */
    @@media print {
        body, .main-content { background: #ffffff !important; }
        .lg-page, .lg-content, .lg-header, .lg-toc { color: #111 !important; background: #fff !important; border: none !important; }
        .lg-toc, .lg-actions { display: none !important; }
        .lg-body { grid-template-columns: 1fr !important; }
        .lg-h2, .lg-title { color: #111 !important; }
        .lg-content p, .lg-content ul { color: #333 !important; }
    }
</style>
}

