@section Scripts {
<script>
    // Highlight current TOC section while scrolling
    (function () {
        var links = document.querySelectorAll('.lg-toc-link');
        var sections = Array.prototype.map.call(links, function (a) {
            var id = a.getAttribute('href').slice(1);
            return document.getElementById(id);
        });

        function onScroll() {
            var fromTop = window.scrollY + 80;
            var activeIdx = 0;
            for (var i = 0; i < sections.length; i++) {
                if (sections[i] && sections[i].offsetTop <= fromTop) activeIdx = i;
            }
            links.forEach(function (a, i) {
                a.classList.toggle('is-active', i === activeIdx);
            });
        }

        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();

        // Smooth-scroll TOC anchors
        links.forEach(function (a) {
            a.addEventListener('click', function (ev) {
                var id = a.getAttribute('href').slice(1);
                var target = document.getElementById(id);
                if (target) { ev.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
            });
        });
    })();
</script>
}
