@model MakauTech.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
    var hasError    = !string.IsNullOrEmpty(ViewBag.Error as string);
    var canShowForm = !hasError && !string.IsNullOrEmpty(Model.Email) && !string.IsNullOrEmpty(Model.Token);
}

@section Styles {
<style>
    body {
        background: #030d06 !important;
    }

    .main-content {
        background: #030d06;
    }

    .fp-wrap {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2.5rem 1.25rem;
    }

    .fp-card {
        width: 100%;
        max-width: 480px;
        background: #0a1812;
        border: 1px solid rgba(16,185,129,0.18);
        border-radius: 18px;
        box-shadow: 0 24px 60px rgba(0,0,0,0.4);
        padding: 2.4rem 2.2rem;
        color: #e5e7eb;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, sans-serif;
    }

    .fp-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(16,185,129,0.12);
        border: 1px solid rgba(16,185,129,0.3);
        color: #6ee7b7;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        padding: 0.3rem 0.85rem;
        border-radius: 999px;
        margin-bottom: 1rem;
    }

    .fp-title {
        font-size: 1.7rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #ffffff;
        margin: 0 0 0.5rem;
    }

    .fp-sub {
        color: rgba(255,255,255,0.62);
        font-size: 0.95rem;
        line-height: 1.55;
        margin: 0 0 1.4rem;
    }

    .fp-label {
        display: block;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 700;
        color: rgba(255,255,255,0.7);
        margin: 0.85rem 0 0.4rem;
    }

    .fp-input {
        width: 100%;
        box-sizing: border-box;
        background: #0b1410;
        color: #ffffff;
        border: 1px solid rgba(16,185,129,0.18);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        font-size: 0.95rem;
        transition: border-color 0.18s, box-shadow 0.18s;
    }

        .fp-input:focus {
            outline: none;
            border-color: rgba(16,185,129,0.55);
            box-shadow: 0 0 0 4px rgba(16,185,129,0.12);
        }

    .fp-submit {
        margin-top: 1.4rem;
        width: 100%;
        background: linear-gradient(135deg,#10b981,#059669);
        color: #ffffff;
        border: none;
        border-radius: 12px;
        padding: 0.9rem 1.1rem;
        font-size: 0.95rem;
        font-weight: 800;
        cursor: pointer;
        box-shadow: 0 8px 22px rgba(16,185,129,0.32);
        transition: filter 0.18s, transform 0.18s;
    }

        .fp-submit:hover {
            filter: brightness(1.07);
            transform: translateY(-1px);
        }

    .fp-error {
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.3);
        color: #fca5a5;
        font-size: 0.88rem;
        padding: 0.7rem 0.9rem;
        border-radius: 10px;
        margin-bottom: 1rem;
        line-height: 1.5;
    }

    .fp-back {
        display: block;
        text-align: center;
        margin-top: 1.2rem;
        font-size: 0.88rem;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
    }

        .fp-back:hover {
            color: #6ee7b7;
        }

    .fp-validation {
        color: #fca5a5;
        font-size: 0.85rem;
        margin-top: 0.35rem;
        display: block;
    }

    .fp-help {
        color: rgba(255,255,255,0.45);
        font-size: 0.78rem;
        margin-top: 0.4rem;
    }
</style>
}

<div class="fp-wrap">
    <div class="fp-card">
        <span class="fp-eyebrow">🔑 Choose a new password</span>
        <h1 class="fp-title">Reset your password</h1>

        @if (hasError)
        {
        <div class="fp-error">@ViewBag.Error</div>
        <p class="fp-sub">
            Reset links are valid for 1 hour and can only be used once.
        </p>
        <a asp-action="ForgotPassword" class="fp-back">← Request a new link</a>
        }
        else if (canShowForm)
        {
        <p class="fp-sub">
            Pick a strong new password for <strong style="color:#ffffff;">@Model.Email</strong>.
            Use 6+ characters with a mix of letters and numbers.
        </p>

        <form asp-action="ResetPassword" method="post" autocomplete="off" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <label class="fp-label" for="rpNewPwd">New password</label>
            <input id="rpNewPwd" type="password" asp-for="NewPassword" class="fp-input" placeholder="••••••••" required autofocus minlength="6" maxlength="128" />
            <span asp-validation-for="NewPassword" class="fp-validation"></span>

            <label class="fp-label" for="rpConfirm">Confirm new password</label>
            <input id="rpConfirm" type="password" asp-for="ConfirmPassword" class="fp-input" placeholder="••••••••" required minlength="6" maxlength="128" />
            <span asp-validation-for="ConfirmPassword" class="fp-validation"></span>

            <button type="submit" class="fp-submit">Update password</button>
            <p class="fp-help">After updating, you'll be redirected to sign in with the new password.</p>
        </form>

        <a asp-action="Login" class="fp-back">← Back to sign in</a>
        }
    </div>
</div>
