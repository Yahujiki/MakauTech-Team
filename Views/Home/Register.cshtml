@model MakauTech.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    int userCount  = ViewBag.UserCount  ?? 0;
    int placeCount = ViewBag.PlaceCount ?? 0;
}

@section Styles {
<style>
    .city-gate {
        position: fixed;
        inset: 0;
        z-index: 8000;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        overflow-y: auto;
        padding: 24px 0;
    }

    .cg-photo {
        position: fixed;
        inset: -4%;
        background-image: url('/Images/heritage-centre.jpg');
        background-size: cover;
        background-position: 50% 38%;
        filter: brightness(0.50) saturate(0.88) contrast(1.12) sepia(0.06);
        will-change: transform;
        transform-origin: center center;
    }

    .cg-overlay {
        position: fixed;
        inset: 0;
        background: linear-gradient(to bottom, rgba(2,8,4,0.52) 0%, rgba(2,8,4,0.18) 30%, rgba(2,8,4,0.12) 52%, rgba(2,8,4,0.42) 75%, rgba(2,8,4,0.82) 100%), radial-gradient(ellipse 90% 70% at 50% 42%, transparent 25%, rgba(0,0,0,0.28) 100%);
    }

    .cg-bg-text {
        position: fixed;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        user-select: none;
        z-index: 0;
    }

    .cg-bg-city {
        font-family: var(--mk-font-display, 'Fraunces', serif);
        font-size: clamp(80px, 14vw, 160px);
        font-weight: 900;
        line-height: 0.88;
        letter-spacing: -0.05em;
        color: rgba(255,255,255,0.05);
        text-align: center;
    }

        .cg-bg-city span {
            display: block;
            -webkit-text-stroke: 1px rgba(255,255,255,0.07);
            color: transparent;
        }

    .cg-particles {
        position: fixed;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
        z-index: 1;
    }

    .cg-dot {
        position: absolute;
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: rgba(52,211,153,0.45);
        animation: cg-float linear infinite;
    }

        .cg-dot:nth-child(1) {
            left: 10%;
            bottom: -6px;
            animation-duration: 20s;
            animation-delay: 0s;
            width: 2px;
            height: 2px;
        }

        .cg-dot:nth-child(2) {
            left: 32%;
            bottom: -6px;
            animation-duration: 24s;
            animation-delay: 3.5s;
        }

        .cg-dot:nth-child(3) {
            left: 58%;
            bottom: -6px;
            animation-duration: 17s;
            animation-delay: 1.5s;
            width: 4px;
            height: 4px;
            opacity: .3;
        }

        .cg-dot:nth-child(4) {
            left: 76%;
            bottom: -6px;
            animation-duration: 21s;
            animation-delay: 5s;
            width: 2px;
            height: 2px;
        }

        .cg-dot:nth-child(5) {
            left: 90%;
            bottom: -6px;
            animation-duration: 15s;
            animation-delay: 2s;
        }

    @@keyframes cg-float {
        0% {
            transform: translateY(0) scale(1);
            opacity: 0;
        }

        5% {
            opacity: 1;
        }

        95% {
            opacity: .5;
        }

        100% {
            transform: translateY(-100vh) scale(0.5);
            opacity: 0;
        }
    }

    .cg-live-badge {
        position: fixed;
        top: 24px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 20;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(52,211,153,0.14);
        border: 1px solid rgba(52,211,153,0.3);
        color: #6ee7b7;
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 4px 14px;
        border-radius: 999px;
        backdrop-filter: blur(6px);
        white-space: nowrap;
    }

        .cg-live-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #34d399;
            animation: cg-pulse 2s ease infinite;
        }

    @@keyframes cg-pulse {
        0%, 100% {
            opacity: 1;
            box-shadow: 0 0 0 0 rgba(52,211,153,0.5);
        }

        50% {
            opacity: .5;
            box-shadow: 0 0 0 4px rgba(52,211,153,0);
        }
    }

    /* card */
    .cg-card {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 420px;
        margin: 60px 16px 24px;
        background: rgba(10,20,14,0.88);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(52,211,153,0.18);
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(0,0,0,0.5), 0 0 0 1px rgba(52,211,153,0.08);
    }

    .cg-shimmer {
        height: 2px;
        background: linear-gradient(90deg,transparent,rgba(52,211,153,0.7) 40%,rgba(16,185,129,1) 50%,rgba(52,211,153,0.7) 60%,transparent);
        background-size: 200% 100%;
        animation: cg-shimmer-move 3s linear infinite;
    }

    @@keyframes cg-shimmer-move {
        0% {
            background-position: -100% 0;
        }

        100% {
            background-position: 200% 0;
        }
    }

    .cg-card-inner {
        padding: 28px 32px 32px;
    }

    .cg-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .cg-brand {
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .cg-brand img {
            width: 26px;
            height: 26px;
            border-radius: 7px;
            opacity: 0.9;
        }

    .cg-brand-name {
        font-family: var(--mk-font-display,'Fraunces',serif);
        font-size: 15px;
        font-weight: 800;
        color: rgba(255,255,255,0.6);
        letter-spacing: -0.02em;
    }

    .cg-back {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        color: rgba(255,255,255,0.28);
        font-size: 11.5px;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-decoration: none;
        transition: color 0.18s;
    }

        .cg-back:hover {
            color: #6ee7b7;
        }

    .cg-live-stats {
        display: flex;
        border: 1px solid rgba(52,211,153,0.15);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 20px;
    }

    .cg-live-stat {
        flex: 1;
        text-align: center;
        padding: 10px 12px;
        border-right: 1px solid rgba(52,211,153,0.1);
    }

        .cg-live-stat:last-child {
            border-right: none;
        }

    .cg-live-stat-n {
        display: block;
        font-family: var(--mk-font-display,'Fraunces',serif);
        font-size: 20px;
        font-weight: 900;
        color: #34d399;
        line-height: 1;
    }

    .cg-live-stat-l {
        display: block;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.28);
        margin-top: 3px;
    }

    .cg-form-label {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #34d399;
        margin-bottom: 6px;
    }

    .cg-form-title {
        font-family: var(--mk-font-display,'Fraunces',serif);
        font-size: clamp(20px,3.5vw,26px);
        font-weight: 800;
        color: #f0fdf4;
        margin: 0 0 4px;
        letter-spacing: -0.03em;
        line-height: 1.15;
    }

    .cg-form-sub {
        font-size: 12.5px;
        color: rgba(255,255,255,0.3);
        margin: 0 0 20px;
    }

    .cg-alert {
        background: rgba(239,68,68,0.12);
        border: 1px solid rgba(239,68,68,0.3);
        border-radius: 8px;
        padding: 10px 12px;
        font-size: 12.5px;
        color: #fca5a5;
        margin-bottom: 16px;
        display: flex;
        align-items: flex-start;
        gap: 7px;
    }

    .cg-field {
        margin-bottom: 18px;
    }

    .cg-field-label {
        display: block;
        font-size: 9.5px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.28);
        margin-bottom: 7px;
    }

    .cg-field-wrap {
        position: relative;
    }

    .cg-field-icon {
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 16px;
        height: 16px;
        color: rgba(255,255,255,0.22);
        pointer-events: none;
        transition: color 0.2s;
    }

    .cg-input {
        width: 100%;
        background: transparent;
        border: none;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding: 9px 0 9px 24px;
        font-size: 14px;
        color: #f0fdf4;
        outline: none;
        transition: border-color 0.2s;
    }

        .cg-input::placeholder {
            color: rgba(255,255,255,0.18);
        }

        .cg-input:focus {
            border-bottom-color: #34d399;
        }

            .cg-input:focus ~ .cg-field-icon {
                color: #34d399;
            }

    .cg-field-line {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 1px;
        width: 0;
        background: #34d399;
        transition: width 0.28s ease;
    }

    .cg-input:focus ~ .cg-field-line {
        width: 100%;
    }

    .cg-submit {
        width: 100%;
        margin-top: 6px;
        background: linear-gradient(135deg,#10b981,#059669);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 14px 20px;
        font-size: 14.5px;
        font-weight: 700;
        letter-spacing: 0.04em;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: opacity 0.18s,transform 0.15s,box-shadow 0.18s;
        box-shadow: 0 4px 18px rgba(16,185,129,0.35);
        position: relative;
        overflow: hidden;
    }

        .cg-submit::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg,transparent,rgba(255,255,255,0.12),transparent);
            transform: translateX(-100%);
            transition: transform 0.5s;
        }

        .cg-submit:hover::after {
            transform: translateX(100%);
        }

        .cg-submit:hover {
            opacity: .9;
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(16,185,129,0.45);
        }

        .cg-submit:active {
            transform: translateY(0);
        }

        .cg-submit svg {
            width: 15px;
            height: 15px;
            transition: transform 0.2s;
        }

        .cg-submit:hover svg {
            transform: translateX(4px);
        }
    /* Agreement row */
    .cg-agree-row {
        margin-bottom: 18px;
        background: rgba(52,211,153,0.05);
        border: 1px solid rgba(52,211,153,0.18);
        border-radius: 10px;
        padding: 12px 14px;
    }

    .cg-agree-label {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        cursor: pointer;
    }

    .cg-agree-check {
        width: 15px;
        height: 15px;
        accent-color: #34d399;
        flex-shrink: 0;
        margin-top: 2px;
        cursor: pointer;
    }

    .cg-agree-label span {
        font-size: 12px;
        color: rgba(255,255,255,0.52);
        line-height: 1.55;
    }

    .cg-agree-link {
        color: #34d399;
        font-weight: 700;
        text-decoration: none;
    }

        .cg-agree-link:hover {
            text-decoration: underline;
        }

    .cg-submit:disabled {
        opacity: 0.55;
        cursor: not-allowed;
    }

    .cg-register {
        margin-top: 16px;
        text-align: center;
        font-size: 12.5px;
        color: rgba(255,255,255,0.28);
    }

        .cg-register a {
            color: #34d399;
            font-weight: 700;
            text-decoration: none;
        }

            .cg-register a:hover {
                text-decoration: underline;
            }

    @@media (max-width: 500px) {
        .cg-card-inner {
            padding: 20px 20px 24px;
        }

        .cg-card {
            margin: 56px 12px 20px;
        }
    }

    @@supports (-webkit-touch-callout: none) {
        .city-gate {
            height: -webkit-fill-available;
        }
    }
</style>
}

<div class="city-gate">
    <div class="cg-photo"></div>
    <div class="cg-overlay"></div>
    <div class="cg-particles">
        <div class="cg-dot"></div><div class="cg-dot"></div>
        <div class="cg-dot"></div><div class="cg-dot"></div><div class="cg-dot"></div>
    </div>

    <div class="cg-card">
        <div class="cg-shimmer"></div>
        <div class="cg-card-inner">

            <div class="cg-card-header">
                <a href="/" class="cg-brand">
                    <img src="/Images/icon.png" alt="MakauTech" />
                    <span class="cg-brand-name">MakauTech</span>
                </a>
                <a href="/" class="cg-back">
                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                    </svg>
                    Home
                </a>
            </div>

            <div class="cg-live-stats">
                <div class="cg-live-stat">
                    <span class="cg-live-stat-n">@userCount</span>
                    <span class="cg-live-stat-l">Explorers</span>
                </div>
                <div class="cg-live-stat">
                    <span class="cg-live-stat-n">@placeCount</span>
                    <span class="cg-live-stat-l">Places</span>
                </div>
                <div class="cg-live-stat">
                    <span class="cg-live-stat-n">Free</span>
                    <span class="cg-live-stat-l">Always</span>
                </div>
            </div>

            <p class="cg-form-label">Create account</p>
            <h1 class="cg-form-title">Start your Sibu story.</h1>
            <p class="cg-form-sub">Free forever. No credit card needed.</p>

            @if (ViewBag.Error != null)
            {
            <div class="cg-alert" role="alert">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;margin-top:1px">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
                <span>@ViewBag.Error</span>
            </div>
            }

            <form method="post" asp-action="Register" novalidate>
                @Html.AntiForgeryToken()

                <div class="cg-field">
                    <label class="cg-field-label" for="regName">Full name</label>
                    <div class="cg-field-wrap">
                        <input id="regName" class="cg-input" type="text" name="Name"
                               placeholder="Your name" autocomplete="name" required />
                        <svg class="cg-field-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                        </svg>
                        <div class="cg-field-line"></div>
                    </div>
                </div>

                <div class="cg-field">
                    <label class="cg-field-label" for="regEmail">Email address</label>
                    <div class="cg-field-wrap">
                        <input id="regEmail" class="cg-input" type="email" name="Email"
                               placeholder="you@example.com" autocomplete="email" required />
                        <svg class="cg-field-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                        </svg>
                        <div class="cg-field-line"></div>
                    </div>
                </div>

                <div class="cg-field">
                    <label class="cg-field-label" for="regPassword">Password</label>
                    <div class="cg-field-wrap">
                        <input id="regPassword" class="cg-input" type="password" name="Password"
                               placeholder="At least 6 characters" autocomplete="new-password" minlength="6" required />
                        <svg class="cg-field-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                        </svg>
                        <div class="cg-field-line"></div>
                    </div>
                </div>

                <!-- Agreement — must tick before registering -->
                <div class="cg-agree-row">
                    <label class="cg-agree-label" for="regAgree">
                        <input type="checkbox" id="regAgree" class="cg-agree-check" />
                        <span>
                            I have read and agree to the
                            <a href="@Url.Action(" Terms","Home")" target="_blank" rel="noopener" class="cg-agree-link">Terms of Service</a>
                            &amp;
                            <a href="@Url.Action(" Privacy","Home")" target="_blank" rel="noopener" class="cg-agree-link">Privacy Policy</a>
                        </span>
                    </label>
                </div>

                <button type="submit" id="regSubmit" class="cg-submit" disabled>
                    Create my account
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                </button>
            </form>

            <div class="cg-register">
                Already have an account? <a asp-action="Login">Sign in →</a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
@await Html.PartialAsync("_AgreementPreview")
<script>
/* ── Agreement gate — unlock register submit when checkbox ticked ── */
(function () {
    var chk = document.getElementById('regAgree');
    var btn = document.getElementById('regSubmit');
    if (!chk || !btn) return;
    function sync() { btn.disabled = !chk.checked; }
    chk.addEventListener('change', sync);
    sync();
}());

/* ══════════════════════════════════════════════════════════════════
   MakauTech Register — Professional parallax engine (shared pattern)
   ══════════════════════════════════════════════════════════════════ */
(function () {
    'use strict';

    var photo = document.querySelector('.cg-photo');
    if (!photo) return;
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var mx = 0.5, my = 0.5;
    var cx = 0,   cy = 0;
    var t  = 0;

    (function loop() {
        t += 0.005;
        var scale = (1.02 + Math.sin(t) * 0.02).toFixed(4);

        var tx = (mx - 0.5) * -28;
        var ty = (my - 0.5) * -18;
        cx += (tx - cx) * 0.03;
        cy += (ty - cy) * 0.03;

        photo.style.transform =
            'scale(' + scale + ') translate(' + cx.toFixed(2) + 'px,' + cy.toFixed(2) + 'px)';

        requestAnimationFrame(loop);
    }());

    window.addEventListener('mousemove', function (e) {
        mx = e.clientX / window.innerWidth;
        my = e.clientY / window.innerHeight;
    }, { passive: true });
}());
</script>
}