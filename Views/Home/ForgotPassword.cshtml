@model MakauTech.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot password";
    var sent = ViewBag.Sent == true;
}

@section Styles {
<style>
    body {
        background: #030d06 !important;
    }

    .main-content {
        background: #030d06;
    }

    .fp-wrap {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2.5rem 1.25rem;
    }

    .fp-card {
        width: 100%;
        max-width: 460px;
        background: #0a1812;
        border: 1px solid rgba(16,185,129,0.18);
        border-radius: 18px;
        box-shadow: 0 24px 60px rgba(0,0,0,0.4);
        padding: 2.4rem 2.2rem;
        color: #e5e7eb;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, sans-serif;
    }

    .fp-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(16,185,129,0.12);
        border: 1px solid rgba(16,185,129,0.3);
        color: #6ee7b7;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        padding: 0.3rem 0.85rem;
        border-radius: 999px;
        margin-bottom: 1rem;
    }

    .fp-title {
        font-size: 1.7rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #ffffff;
        margin: 0 0 0.5rem;
    }

    .fp-sub {
        color: rgba(255,255,255,0.62);
        font-size: 0.95rem;
        line-height: 1.55;
        margin: 0 0 1.5rem;
    }

    .fp-label {
        display: block;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 700;
        color: rgba(255,255,255,0.7);
        margin-bottom: 0.4rem;
    }

    .fp-input {
        width: 100%;
        box-sizing: border-box;
        background: #0b1410;
        color: #ffffff;
        border: 1px solid rgba(16,185,129,0.18);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        font-size: 0.95rem;
        transition: border-color 0.18s, box-shadow 0.18s;
    }

        .fp-input:focus {
            outline: none;
            border-color: rgba(16,185,129,0.55);
            box-shadow: 0 0 0 4px rgba(16,185,129,0.12);
        }

    .fp-submit {
        margin-top: 1.25rem;
        width: 100%;
        background: linear-gradient(135deg,#10b981,#059669);
        color: #ffffff;
        border: none;
        border-radius: 12px;
        padding: 0.9rem 1.1rem;
        font-size: 0.95rem;
        font-weight: 800;
        cursor: pointer;
        box-shadow: 0 8px 22px rgba(16,185,129,0.32);
        transition: filter 0.18s, transform 0.18s;
    }

        .fp-submit:hover {
            filter: brightness(1.07);
            transform: translateY(-1px);
        }

    .fp-error {
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.3);
        color: #fca5a5;
        font-size: 0.88rem;
        padding: 0.7rem 0.9rem;
        border-radius: 10px;
        margin-bottom: 1rem;
        line-height: 1.5;
    }

    .fp-success {
        background: rgba(16,185,129,0.06);
        border: 1px solid rgba(16,185,129,0.32);
        color: #6ee7b7;
        font-size: 0.92rem;
        padding: 1rem 1.1rem;
        border-radius: 12px;
        margin-bottom: 1.2rem;
        line-height: 1.6;
    }

        .fp-success strong {
            color: #ffffff;
            display: block;
            margin-bottom: 0.2rem;
        }

    .fp-back {
        display: block;
        text-align: center;
        margin-top: 1.2rem;
        font-size: 0.88rem;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
    }

        .fp-back:hover {
            color: #6ee7b7;
        }

    .fp-validation {
        color: #fca5a5;
        font-size: 0.85rem;
        margin-top: 0.35rem;
    }
</style>
}

<div class="fp-wrap">
    <div class="fp-card">

        @if (sent)
        {
        <span class="fp-eyebrow">📨 Check your inbox</span>
        <h1 class="fp-title">Email sent</h1>
        <div class="fp-success">
            <strong>If an account exists for @Model.Email…</strong>
            we've sent a password reset link to it. The link will expire in 1 hour.
        </div>
        <p class="fp-sub" style="margin:0;">
            Didn't get the email? Check your spam folder or
            <a asp-action="ForgotPassword" style="color:#6ee7b7;text-decoration:none;font-weight:700;">try again</a>.
        </p>
        <a asp-action="Login" class="fp-back">← Back to sign in</a>
        }
        else
        {
        <span class="fp-eyebrow">🔑 Reset your password</span>
        <h1 class="fp-title">Forgot your password?</h1>
        <p class="fp-sub">
            No problem — enter the email address tied to your MakauTech account and we'll send you a link to reset it.
        </p>

        @if (!string.IsNullOrEmpty(ViewBag.Error as string))
        {
        <div class="fp-error">@ViewBag.Error</div>
        }

        <form asp-action="ForgotPassword" method="post" autocomplete="off" novalidate>
            @Html.AntiForgeryToken()

            <label class="fp-label" for="fpEmail">Email address</label>
            <input id="fpEmail" type="email" asp-for="Email" class="fp-input" placeholder="you@example.com" required autofocus />
            <span asp-validation-for="Email" class="fp-validation"></span>

            <button type="submit" class="fp-submit">Send reset link</button>
        </form>

        <a asp-action="Login" class="fp-back">← Back to sign in</a>
        }

    </div>
</div>
