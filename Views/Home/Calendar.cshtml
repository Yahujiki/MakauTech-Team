@using MakauTech.Helpers
@model IReadOnlyList<MakauTech.Helpers.SibuEvent>
@{
    ViewData["Title"] = "Sibu Calendar";
    int month = ViewBag.CurrentMonth ?? DateTime.Today.Month;
    int year  = ViewBag.CurrentYear  ?? DateTime.Today.Year;

    int prevMonth = month == 1 ? 12 : month - 1;
    int prevYear  = month == 1 ? year - 1 : year;
    int nextMonth = month == 12 ? 1 : month + 1;
    int nextYear  = month == 12 ? year + 1 : year;

    var monthName = new DateTime(year, month, 1).ToString("MMMM yyyy");
    var firstDay  = new DateTime(year, month, 1);
    var daysInMonth = DateTime.DaysInMonth(year, month);
    int weekOffset = ((int)firstDay.DayOfWeek + 6) % 7;  // Mon=0, Sun=6

    var monthEvents = Model.Where(e => e.Date.Year == year && e.Date.Month == month).ToList();
    var byDay = monthEvents.ToLookup(e => e.Date.Day);

    var upcoming = Model.Where(e => e.Date.Date >= DateTime.Today).OrderBy(e => e.Date).Take(8).ToList();
}

@section Styles {
    <style>
        .cal-wrap { max-width: 1100px; margin: 32px auto; padding: 0 20px; }
        .cal-head { display: flex; align-items: end; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 24px; }
        .cal-eyebrow { display: inline-block; padding: 4px 14px; background: rgba(16,185,129,0.12); color: var(--mk-emerald-700); border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px; }
        .cal-title { font-family: var(--mk-font-display); font-size: clamp(28px, 4vw, 40px); font-weight: 700; color: var(--mk-night-900); margin: 0 0 4px; letter-spacing: -0.02em; }
        .cal-sub { color: var(--mk-slate-600); font-size: 14.5px; margin: 0; }

        .cal-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 24px;
        }
        @@media (max-width: 880px) { .cal-grid { grid-template-columns: 1fr; } }

        .cal-month {
            background: #fff;
            border: 1px solid rgba(15,23,42,0.06);
            border-radius: var(--mk-r-lg);
            padding: 22px;
            box-shadow: var(--mk-shadow);
        }
        .cal-month-bar {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 16px;
        }
        .cal-month-name { font-family: var(--mk-font-display); font-size: 22px; font-weight: 700; color: var(--mk-night-900); margin: 0; letter-spacing: -0.01em; }
        .cal-nav-btn {
            width: 36px; height: 36px;
            display: grid; place-items: center;
            border-radius: 50%;
            border: 1px solid rgba(15,23,42,0.12);
            background: #fff;
            color: var(--mk-slate-700);
            text-decoration: none;
            font-weight: 700;
            transition: background 0.18s, border-color 0.18s, color 0.18s;
        }
        .cal-nav-btn:hover { background: var(--mk-emerald-50); border-color: var(--mk-emerald-300); color: var(--mk-emerald-700); }

        .cal-grid-week {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 6px;
        }
        .cal-dow {
            text-align: center;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--mk-slate-500, #64748b);
            padding: 6px 0;
        }
        .cal-day {
            position: relative;
            aspect-ratio: 1;
            border-radius: var(--mk-r-sm);
            background: #f8fafc;
            border: 1px solid transparent;
            padding: 6px 8px;
            display: flex;
            flex-direction: column;
            font-size: 12px;
            color: var(--mk-slate-700);
            min-height: 56px;
        }
        .cal-day-empty { background: transparent; border: none; }
        .cal-day-num { font-weight: 700; color: var(--mk-night-900); font-size: 13px; }
        .cal-day-today { background: var(--mk-emerald-50); border-color: var(--mk-emerald-300); }
        .cal-day-today .cal-day-num { color: var(--mk-emerald-700); }
        .cal-day-has-event { background: linear-gradient(135deg, #fffbeb, #fef3c7); border-color: rgba(245,158,11,0.32); }
        .cal-day-has-event .cal-day-num { color: #92400e; }
        .cal-day-emoji { font-size: 18px; margin-top: auto; line-height: 1; }
        .cal-day-count { font-size: 10px; font-weight: 700; color: var(--mk-slate-500, #64748b); margin-top: 2px; }

        .cal-list {
            background: #fff;
            border: 1px solid rgba(15,23,42,0.06);
            border-radius: var(--mk-r-lg);
            padding: 22px;
            box-shadow: var(--mk-shadow);
        }
        .cal-list h3 { font-family: var(--mk-font-display); font-size: 17px; font-weight: 700; color: var(--mk-night-900); margin: 0 0 14px; letter-spacing: -0.01em; }
        .cal-event {
            display: grid;
            grid-template-columns: 56px 1fr;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px dashed rgba(15,23,42,0.08);
        }
        .cal-event:last-child { border-bottom: none; }
        .cal-event-date {
            text-align: center;
            background: linear-gradient(135deg, var(--mk-emerald-50), #fff);
            border: 1px solid rgba(16,185,129,0.24);
            border-radius: 10px;
            padding: 4px 0;
        }
        .cal-event-date .day { display: block; font-family: var(--mk-font-display); font-size: 22px; font-weight: 800; color: var(--mk-emerald-700); line-height: 1; }
        .cal-event-date .mon { display: block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--mk-slate-500, #64748b); margin-top: 2px; }
        .cal-event-body .title { font-weight: 700; color: var(--mk-night-900); font-size: 14px; }
        .cal-event-body .meta { font-size: 12px; color: var(--mk-slate-600); margin-top: 2px; }
        .cal-event-body .cat { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; margin-top: 4px; background: rgba(16,185,129,0.14); color: var(--mk-emerald-700); }

        [data-theme="dark"] .cal-month, [data-theme="dark"] .cal-list { background: var(--mk-night-800); border-color: rgba(255,255,255,0.06); }
        [data-theme="dark"] .cal-day { background: rgba(255,255,255,0.04); color: #cbd5e1; }
        [data-theme="dark"] .cal-day-num, [data-theme="dark"] .cal-event-body .title, [data-theme="dark"] .cal-month-name { color: #f1f5f9; }
        [data-theme="dark"] .cal-title { color: #f1f5f9; }
    </style>
}

<div class="cal-wrap">
    <div class="cal-head mk-fade-in">
        <div>
            <span class="cal-eyebrow">📅 What's on</span>
            <h1 class="cal-title">Sibu Calendar</h1>
            <p class="cal-sub">Festivals, public holidays and notable dates around Sibu &amp; Sarawak. Plan your visit around the food.</p>
        </div>
    </div>

    <div class="cal-grid">
        <div class="cal-month mk-fade-in">
            <div class="cal-month-bar">
                <a href="@Url.Action("Calendar","Home", new { month = prevMonth, year = prevYear })" class="cal-nav-btn" aria-label="Previous month">‹</a>
                <h2 class="cal-month-name">@monthName</h2>
                <a href="@Url.Action("Calendar","Home", new { month = nextMonth, year = nextYear })" class="cal-nav-btn" aria-label="Next month">›</a>
            </div>

            <div class="cal-grid-week">
                <div class="cal-dow">Mon</div>
                <div class="cal-dow">Tue</div>
                <div class="cal-dow">Wed</div>
                <div class="cal-dow">Thu</div>
                <div class="cal-dow">Fri</div>
                <div class="cal-dow">Sat</div>
                <div class="cal-dow">Sun</div>

                @for (int i = 0; i < weekOffset; i++)
                {
                    <div class="cal-day cal-day-empty"></div>
                }

                @for (int d = 1; d <= daysInMonth; d++)
                {
                    var dayEvents = byDay[d].ToList();
                    var isToday = (year == DateTime.Today.Year && month == DateTime.Today.Month && d == DateTime.Today.Day);
                    var classes = "cal-day";
                    if (isToday) classes += " cal-day-today";
                    if (dayEvents.Count > 0) classes += " cal-day-has-event";
                    var firstEvent = dayEvents.FirstOrDefault();
                    <div class="@classes" title="@(firstEvent?.Title ?? "")">
                        <span class="cal-day-num">@d</span>
                        @if (firstEvent != null)
                        {
                            <span class="cal-day-emoji" aria-hidden="true">@firstEvent.Emoji</span>
                            @if (dayEvents.Count > 1)
                            {
                                <span class="cal-day-count">+@(dayEvents.Count - 1) more</span>
                            }
                        }
                    </div>
                }
            </div>
        </div>

        <div class="cal-list mk-fade-in mk-fade-in-2">
            <h3>Upcoming events</h3>
            @if (!upcoming.Any())
            {
                <p style="color:var(--mk-slate-600); font-size:13px; margin:0;">No upcoming events on the calendar.</p>
            }
            else
            {
                foreach (var e in upcoming)
                {
                    <div class="cal-event">
                        <div class="cal-event-date">
                            <span class="day">@e.Date.Day</span>
                            <span class="mon">@e.Date.ToString("MMM")</span>
                        </div>
                        <div class="cal-event-body">
                            <div class="title">@e.Emoji @e.Title</div>
                            <div class="meta">@e.Location</div>
                            <span class="cat">@e.Category</span>
                            @if (!string.IsNullOrEmpty(e.Note))
                            {
                                <div class="meta" style="margin-top:6px; font-style:italic;">@e.Note</div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
