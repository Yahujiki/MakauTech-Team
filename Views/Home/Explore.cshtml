@@model MakauTech.Models.HomeViewModel
@{
    ViewData["Title"] = "Explore Sibu";
    var ph = Url.Content("~/Images/placeholder.svg");
}

<!-- ── Legendary Explore Hero ── -->
<div class="explore-hero">
    <span class="explore-hero-kicker">🗺️ Discover Sibu</span>
    <h1>Explore <span>Sarawak's Hidden Gems</span></h1>
    <p>Search landmarks, nature spots, food &amp; heritage — visit in person to earn points and unlock badges.</p>

    <form method="get" asp-controller="Home" asp-action="Explore" class="explore-search-wrap">
        <div class="explore-search-bar">
            <input type="text" name="search" value="@Model.SearchQuery"
                   placeholder="Search places, landmarks, food…"
                   class="search-input" autocomplete="off" />
            <select name="categoryId" class="search-select">
                <option value="">All categories</option>
                @foreach (var cat in Model.Categories)
                {
                if (Model.SelectedCategory == cat.Id)
                {
                <option value="@cat.Id" selected>@cat.Icon @cat.Name</option>
                }
                else
                {
                <option value="@cat.Id">@cat.Icon @cat.Name</option>
                }
                }
            </select>
            <button type="submit" class="btn-search">Search</button>
        </div>
    </form>
</div>

<!-- ── Results ── -->
<div class="explore-body">
    <div class="explore-count-bar">
        <div class="explore-count">
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery) || Model.SelectedCategory != null)
            {
            <strong>@Model.Places.Count</strong> <span>@(Model.Places.Count == 1 ? "result" : "results") found</span>
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
            <span>for "<em>@Model.SearchQuery</em>"</span>
            }
            }
            else
            {
            <span>Showing <strong>@Model.Places.Count</strong> place@(Model.Places.Count == 1 ? "" : "s") in Sibu</span>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.SearchQuery) || Model.SelectedCategory != null)
        {
        <a asp-controller="Home" asp-action="Explore" style="font-size:0.85rem;font-weight:700;color:var(--accent-hover)">✕ Clear filters</a>
        }
    </div>

    @if (Model.Places.Count == 0)
    {
    <div class="lb-empty" style="margin-top:1rem">
        <div style="font-size:3rem">🔍</div>
        <p><strong>No places found.</strong></p>
        <p>Try a different search term or clear the category filter.</p>
        <a asp-controller="Home" asp-action="Explore" class="btn-primary" style="display:inline-block;margin-top:1rem">Clear search</a>
    </div>
    }
    else
    {
    <div class="places-grid">
        @foreach (var place in Model.Places)
        {
        var likeCount = Model.LikeCounts.ContainsKey(place.Id) ? Model.LikeCounts[place.Id] : 0;
        <div class="place-card scroll-reveal">
            <div class="place-image-wrap">
                <img src="@PlaceImageUrl.Resolve(Url, place.ImageUrl)"
                     alt="@place.Name" loading="lazy"
                     onerror="this.onerror=null;this.src='@ph'" />
                <span class="place-category">@place.Category?.Icon @place.Category?.Name</span>
            </div>
            <div class="place-info">
                <h3>@place.Name</h3>
                <p class="place-location">📍 @place.Location</p>
                <p class="place-desc">@(!string.IsNullOrWhiteSpace(place.Description) ? place.Description : "A great Sibu stop — share your experience when you visit!")</p>
                <div class="place-meta">
                    @if (place.VisitCount > 0 && place.Rating > 0)
                    {
                    <span class="place-rating">⭐ @place.Rating.ToString("F1")</span>
                    }
                    else
                    {
                    <span class="place-rating no-rating">Be the first to rate</span>
                    }
                    <span class="place-visits">@place.VisitCount visit@(place.VisitCount == 1 ? "" : "s")</span>
                    @if (likeCount > 0)
                    {
                    <span class="place-likes-badge">❤️ @likeCount</span>
                    }
                </div>
                <a asp-controller="Place" asp-action="Detail" asp-route-id="@place.Id" class="btn-visit">View details →</a>
            </div>
        </div>
        }
    </div>
    }
</div>

@section Scripts {
<script>
// Scroll-reveal for place cards
const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); observer.unobserve(e.target); } });
}, { threshold: 0.08 });
document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
</script>
}

