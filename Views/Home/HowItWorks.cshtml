@{
    ViewData["Title"] = "How it works";
}

<section class="page-hero page-hero--compact">
    <h1>How it works</h1>
    <p>Earn points fairly: visits are free to log; likes and written reviews reward engagement.</p>
</section>

<section class="gamification-section how-page">
    <div class="gamification-grid">
        <div class="gamification-card">
            <div class="gamification-icon">♥</div>
            <h2>Like places</h2>
            <p>Save favourites and show support for Sibu spots you care about.</p>
        </div>
        <div class="gamification-card">
            <div class="gamification-icon">✎</div>
            <h2>Like + review</h2>
            <p>After you like a place, add a written review for <strong>+10 points</strong> total from that combo.</p>
        </div>
        <div class="gamification-card">
            <div class="gamification-icon">◇</div>
            <h2>Play games</h2>
            <p>Spend a small points entry on minigames and win more back with a strong run.</p>
        </div>
        <div class="gamification-card">
            <div class="gamification-icon">◆</div>
            <h2>Earn badges</h2>
            <p>Unlock achievements as you explore — check the Achievements page for the full set.</p>
        </div>
    </div>
</section>
