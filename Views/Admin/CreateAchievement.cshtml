@{
    ViewData["Title"] = "Create Achievement";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}
<h2>Add Achievement</h2>
<form method="post" asp-action="CreateAchievement" class="admin-form">
    <div class="form-group"><label>Name</label><input type="text" name="name" class="form-control" required /></div>
    <div class="form-group"><label>Description</label><input type="text" name="description" class="form-control" required /></div>
    <div class="form-group"><label>Icon (emoji)</label><input type="text" name="icon" class="form-control" placeholder="🏆" required /></div>
    <div class="form-group"><label>Points Required</label><input type="number" name="pointsRequired" class="form-control" value="0" /></div>
    <div class="form-group"><label>Places Required</label><input type="number" name="placesRequired" class="form-control" value="0" /></div>
    <button type="submit" class="admin-btn">Save</button>
    <a asp-action="Achievements" class="admin-btn" style="background:#666">Cancel</a>
</form>