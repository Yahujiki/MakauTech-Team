@model List<MakauTech.Models.Category>
@{
    ViewData["Title"] = "Categories";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="admin-page-header">
    <h2>Categories</h2>
    <a asp-action="CreateCategory" class="admin-btn">+ Add Category</a>
</div>

<table class="admin-table">
    <thead><tr><th>Icon</th><th>Name</th><th>Actions</th></tr></thead>
    <tbody>
        @foreach (var cat in Model)
        {
            <tr>
                <td>@cat.Icon</td>
                <td>@cat.Name</td>
                <td>
                    <form method="post" asp-action="DeleteCategory" style="display:inline">
                        <input type="hidden" name="id" value="@cat.Id" />
                        <button type="submit" class="admin-btn-sm admin-btn-danger" onclick="return confirm('Delete?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>