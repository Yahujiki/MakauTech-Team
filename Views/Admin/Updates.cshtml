@model List<MakauTech.Models.Update>
@{
    ViewData["Title"] = "Updates";
    Layout = "_AdminLayout";
}

<div style="display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; margin-bottom:24px;">
    <div>
        <h1 class="admin-section-title" style="font-size:28px; margin:0 0 4px;">📢 Daily Updates</h1>
        <p style="color:rgba(255,255,255,0.55); margin:0; font-size:14px;">Post announcements visible to all visitors (logged in or not).</p>
    </div>
    <a asp-action="CreateUpdate" class="admin-btn admin-btn-primary" style="padding:0.6rem 1.2rem;">＋ New Update</a>
</div>

@if (TempData["AdminSuccess"] != null) {
    <div style="background:rgba(34,197,94,0.12); border:1px solid rgba(34,197,94,0.32); color:#6ee7b7; padding:12px 18px; border-radius:10px; margin-bottom:18px;">✅ @TempData["AdminSuccess"]</div>
}
@if (TempData["AdminError"] != null) {
    <div style="background:rgba(239,68,68,0.12); border:1px solid rgba(239,68,68,0.32); color:#fca5a5; padding:12px 18px; border-radius:10px; margin-bottom:18px;">⚠️ @TempData["AdminError"]</div>
}

@if (!Model.Any())
{
    <div style="text-align:center; padding:64px 24px; background:rgba(255,255,255,0.04); border:1px dashed rgba(255,255,255,0.12); border-radius:18px; color:rgba(255,255,255,0.6);">
        <div style="font-size:48px; margin-bottom:12px;">📭</div>
        <h2 style="font-family:'Fraunces',serif; margin:0 0 8px;">No updates yet</h2>
        <p style="margin:0 0 16px;">Click "New Update" to publish your first announcement.</p>
    </div>
}
else
{
    <table class="admin-table" style="width:100%; border-collapse:collapse;">
        <thead>
            <tr>
                <th style="width:90px;">Date</th>
                <th>Title</th>
                <th>Author</th>
                <th style="width:100px; text-align:center;">Status</th>
                <th style="width:160px; text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td style="font-size:12px; color:rgba(255,255,255,0.55);">@u.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>
                        <a href="@Url.Action("UpdateDetail","Home",new{id=u.Id})" target="_blank" style="color:#6ee7b7; font-weight:600; text-decoration:none;">@u.Title</a>
                        @if (!string.IsNullOrEmpty(u.Summary))
                        {
                            <div style="color:rgba(255,255,255,0.5); font-size:12.5px; margin-top:4px;">@(u.Summary.Length > 80 ? u.Summary[..80] + "…" : u.Summary)</div>
                        }
                    </td>
                    <td style="color:rgba(255,255,255,0.65); font-size:13px;">@u.AuthorName</td>
                    <td style="text-align:center;">
                        @if (u.IsPublished) {
                            <span class="admin-pill admin-pill-ok">Published</span>
                        } else {
                            <span class="admin-pill admin-pill-warn">Hidden</span>
                        }
                    </td>
                    <td style="text-align:right;">
                        <a asp-action="EditUpdate" asp-route-id="@u.Id" class="admin-btn-sm" style="padding:0.4rem 0.85rem; background:rgba(255,255,255,0.08); color:#e2e8f0; text-decoration:none; border-radius:999px; font-size:12px; font-weight:600;">✏️ Edit</a>
                        <form method="post" asp-action="DeleteUpdate" asp-route-id="@u.Id" style="display:inline;" onsubmit="return confirm('Delete this update? Cannot be undone.');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="admin-btn-sm admin-btn-danger" style="padding:0.4rem 0.85rem; font-size:12px;">🗑 Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
