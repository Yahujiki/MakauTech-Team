@{
    ViewData["Title"] = "Create Place";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<h2>Add New Place</h2>
<form method="post" asp-action="CreatePlace" class="admin-form">
    <div class="form-group"><label>Name</label><input type="text" name="name" class="form-control" required /></div>
    <div class="form-group"><label>Location</label><input type="text" name="location" class="form-control" required /></div>
    <div class="form-group"><label>Description</label><textarea name="description" class="form-control" rows="3" required></textarea></div>
    <div class="form-group"><label>Image URL</label><input type="text" name="imageUrl" class="form-control" placeholder="/Images/your-photo.jpg" /></div>
    <div class="form-group"><label>Rating (1-5)</label><input type="number" name="rating" class="form-control" step="0.1" min="1" max="5" value="4.0" required /></div>
    <div class="form-group">
        <label>Category</label>
        <select name="categoryId" class="form-control">
            @foreach (var cat in (List<MakauTech.Models.Category>)ViewBag.Categories)
            {
                <option value="@cat.Id">@cat.Icon @cat.Name</option>
            }
        </select>
    </div>
    <button type="submit" class="admin-btn">Save Place</button>
    <a asp-action="Places" class="admin-btn" style="background:#666">Cancel</a>
</form>