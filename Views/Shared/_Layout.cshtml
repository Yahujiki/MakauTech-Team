        <div class="app-main">
            <header class="topbar">
                @if (ViewBag.IsLoggedIn == true)
                {
                    <button type="button" class="topbar-menu" id="sidebarOpen" aria-expanded="false" aria-controls="app-sidebar" aria-label="Open menu">
                        <span class="topbar-burger" aria-hidden="true"></span>
                        <span class="topbar-burger" aria-hidden="true"></span>
                        <span class="topbar-burger" aria-hidden="true"></span>
                    </button>
                }
                <div class="topbar-title">
                    <a asp-controller="Home" asp-action="Index" class="topbar-logo-link"><img src="~/Images/icon.png" alt="Home" class="topbar-logo" /></a>
                    <span class="topbar-brand-text"><span class="brand-makau">Makau</span><span class="brand-tech">Tech</span></span>
                </div>
                @if (ViewBag.IsLoggedIn != true && ViewBag.HideAuthButtons != true)
