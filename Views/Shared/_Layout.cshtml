    }
    #riva-input:focus { border-color: #22c55e; }
    #riva-send, #riva-mic {
        width: 38px; height: 38px; border: none; border-radius: 10px;
        cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center;
        transition: background 0.18s, transform 0.15s;
    }
    #riva-send { background: linear-gradient(135deg, #22c55e, #16a34a); color: #fff; }
    #riva-send:hover { filter: brightness(1.1); transform: scale(1.06); }
    #riva-mic { background: #f0fdf4; color: #166534; border: 1.5px solid #bbf7d0; }
    #riva-mic:hover { background: #dcfce7; }
    #riva-mic.riva-listening { background: #fee2e2; color: #991b1b; border-color: #fca5a5; animation: riva-pulse 0.8s infinite; }
    @@media(max-width:480px){ #riva-panel{right:0.75rem;bottom:5rem;width:calc(100vw - 1.5rem);} #riva-fab{right:1rem;bottom:1rem;} }
    </style>

    <script>
    (function() {
        const fab = document.getElementById('riva-fab');
        const panel = document.getElementById('riva-panel');
        const closeBtn = document.getElementById('riva-close');
        const sendBtn = document.getElementById('riva-send');
        const input = document.getElementById('riva-input');
        const messages = document.getElementById('riva-messages');
        const micBtn = document.getElementById('riva-mic');
        const ttsToggle = document.getElementById('riva-tts-toggle');

        let ttsEnabled = false;
        let recognition = null;
        let isListening = false;

        // Toggle panel
        fab.addEventListener('click', function() {
            const open = panel.classList.toggle('riva-open');
            panel.setAttribute('aria-hidden', String(!open));
            if (open) { input.focus(); fab.querySelector('#riva-fab-icon').textContent = '✕'; }
            else { fab.querySelector('#riva-fab-icon').textContent = '🦢'; }
        });
        closeBtn.addEventListener('click', function() {
            panel.classList.remove('riva-open');
            panel.setAttribute('aria-hidden', 'true');
            fab.querySelector('#riva-fab-icon').textContent = '🦢';
        });

        // TTS toggle — off by default, user must click to enable
        ttsToggle.addEventListener('click', function() {
            ttsEnabled = !ttsEnabled;
            ttsToggle.classList.toggle('riva-tts-off', !ttsEnabled);
            ttsToggle.textContent = ttsEnabled ? '🔊' : '🔇';
            ttsToggle.title = ttsEnabled ? 'Voice on — click to mute' : 'Voice off — click to enable';
            if (!ttsEnabled && window.speechSynthesis) window.speechSynthesis.cancel();
        });

        function safeHtml(s) {
            if (window.MakauSecurity && typeof MakauSecurity.escapeHtml === 'function')
                return MakauSecurity.escapeHtml(s).replace(/\n/g, '<br>');
            // Fallback: no HTML allowed.
            return String(s || '').replace(/\n/g, '<br>');
        }

        function addMsg(text, who) {
            const row = document.createElement('div');
            row.className = 'riva-msg riva-msg--' + who;
            const av = document.createElement('span');
            av.className = 'riva-msg-avatar';
            av.textContent = who === 'bot' ? '🦢' : '👤';
            const bubble = document.createElement('div');
            bubble.className = 'riva-msg-bubble';
            bubble.innerHTML = safeHtml(text);
            if (who === 'bot') { row.appendChild(av); row.appendChild(bubble); }
            else { row.appendChild(bubble); row.appendChild(av); }
            messages.appendChild(row);
            messages.scrollTop = messages.scrollHeight;
            return row;
        }

        function showTyping() {
            const row = document.createElement('div');
            row.className = 'riva-msg riva-msg--bot riva-typing';
            row.id = 'riva-typing';
            row.innerHTML = '<span class="riva-msg-avatar">🦢</span><div class="riva-msg-bubble"><span class="riva-dot"></span><span class="riva-dot"></span><span class="riva-dot"></span></div>';
            messages.appendChild(row);
            messages.scrollTop = messages.scrollHeight;
        }
        function hideTyping() {
            const t = document.getElementById('riva-typing');
            if (t) t.remove();
        }

        function speak(text) {
            if (!ttsEnabled || !window.speechSynthesis) return;
            window.speechSynthesis.cancel();
            const plain = text.replace(/<[^>]+>/g, '').replace(/[🤖👋🍜🌿🏛️🚢🛒🎮🏆💪🏅🌤️✈️🏙️🚀📍😊🏃]/gu, '');
            const utt = new SpeechSynthesisUtterance(plain);
            utt.lang = 'en-GB'; utt.rate = 1; utt.pitch = 1.05;
            // Pick a female voice if available
            const voices = window.speechSynthesis.getVoices();
            const female = voices.find(v => /female|woman|zira|samantha|karen|victoria|fiona/i.test(v.name));
            if (female) utt.voice = female;
            window.speechSynthesis.speak(utt);
        }

        async function sendMessage(text) {
            if (!text.trim()) return;
            addMsg(text, 'user');
            input.value = '';
            sendBtn.disabled = true;
            showTyping();
            try {
                const res = (window.MakauSecurity && MakauSecurity.csrfFetch)
                    ? await MakauSecurity.csrfFetch('/api/ai/chat', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: text })
                    })
                    : await fetch('/api/ai/chat', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: text })
                    });
                const data = await res.json();
                hideTyping();
                var reply = (data && data.reply) ? String(data.reply) : 'Hmm, something went wrong.';
                addMsg(reply, 'bot');
                speak(reply);
            } catch(e) {
                hideTyping();
                addMsg('Sorry, I\'m having trouble connecting. Try again in a moment, lah!', 'bot');
            } finally { sendBtn.disabled = false; }
        }

        sendBtn.addEventListener('click', function() { sendMessage(input.value); });
        input.addEventListener('keydown', function(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(input.value); } });

        // Voice input (Speech Recognition)
        const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
        if (SpeechRec) {
            recognition = new SpeechRec();
            recognition.lang = 'en-MY'; // Malaysian English
            recognition.interimResults = false;
            recognition.maxAlternatives = 1;

            recognition.onresult = function(e) {
                const transcript = e.results[0][0].transcript;
                input.value = transcript;
                isListening = false;
                micBtn.classList.remove('riva-listening');
                sendMessage(transcript);
            };
            recognition.onerror = function() {
                isListening = false;
                micBtn.classList.remove('riva-listening');
            };
            recognition.onend = function() {
                isListening = false;
                micBtn.classList.remove('riva-listening');
            };

            micBtn.addEventListener('click', function() {
                if (isListening) { recognition.stop(); return; }
                try {
                    recognition.start();
                    isListening = true;
                    micBtn.classList.add('riva-listening');
                } catch(e) {}
            });
        } else {
            micBtn.title = 'Voice not supported in this browser';
            micBtn.style.opacity = '0.4';
            micBtn.style.cursor = 'default';
        }

        // Load voices for TTS (Chrome needs this)
        if (window.speechSynthesis) {
            window.speechSynthesis.getVoices();
            window.speechSynthesis.addEventListener('voiceschanged', function() {
                window.speechSynthesis.getVoices();
            });
        }
    })();
    </script>

    <!-- ═══ SIGNALR REALTIME ═══ -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
    (function(){
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/notifications")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveNotification", function(message, type) {
            showMakauToast(message, type);
        });

        connection.on("LeaderboardUpdate", function(userName, newScore) {
            var row = document.querySelector('[data-user="' + userName + '"]');
            if (row) {
                var scoreEl = row.querySelector('.score');
                if (scoreEl) scoreEl.textContent = newScore + ' pts';
            }
        });

        connection.on("BadgeEarned", function(userName, badgeName) {
            showMakauToast("\ud83c\udfc6 " + userName + " earned '" + badgeName + "'!", "success");
        });

        connection.start().catch(function(err) {
            console.log("SignalR:", err.toString());
        });

        function showMakauToast(message, type) {
            type = type || 'info';
            var toast = document.createElement('div');
            toast.className = 'makau-toast makau-toast--' + type;
            toast.textContent = String(message || '');
            var colors = { success: '#10b981', warning: '#f59e0b', info: '#6366f1', error: '#ef4444' };
            toast.style.cssText = 'position:fixed;top:20px;right:20px;z-index:99999;padding:14px 24px;border-radius:12px;color:#fff;font-weight:600;font-size:0.95rem;max-width:380px;box-shadow:0 8px 32px rgba(0,0,0,0.3);animation:makauSlideIn 0.4s ease;background:' + (colors[type] || colors.info) + ';';
            document.body.appendChild(toast);
            setTimeout(function(){ toast.style.opacity='0'; toast.style.transition='opacity 0.4s'; }, 4000);
            setTimeout(function(){ toast.remove(); }, 4500);
        }
    })();
    </script>
    <style>
    @@keyframes makauSlideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    </style>
</body>
</html>
