            <button id="riva-mic" title="Hold to speak" aria-label="Voice input">🎤</button>
            <input id="riva-input" type="text" placeholder="Ask about Sibu food, places, games…" autocomplete="off" maxlength="200" />
            <button id="riva-send" aria-label="Send message">➤</button>
        </div>
    </div>

    <style>
    #riva-fab {
        position: fixed; bottom: 1.75rem; right: 1.75rem; z-index: 9000;
        width: 58px; height: 58px; border-radius: 50%;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        box-shadow: 0 6px 24px rgba(34,197,94,0.5);
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem; transition: transform 0.2s, box-shadow 0.2s;
        user-select: none;
    }
    #riva-fab:hover { transform: scale(1.1); box-shadow: 0 8px 32px rgba(34,197,94,0.65); }
    #riva-fab-pulse {
        position: absolute; top: 2px; right: 2px; width: 14px; height: 14px;
        background: #f59e0b; border-radius: 50%; border: 2px solid #fff;
        /* static dot — no blink */
    }
    @@keyframes riva-pulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.3);opacity:0.7} }

    #riva-panel {
        position: fixed; bottom: 5.5rem; right: 1.75rem; z-index: 8999;
        width: 360px; max-width: calc(100vw - 2rem);
        background: #fff; border-radius: 20px;
        box-shadow: 0 20px 60px rgba(7,29,15,0.22), 0 0 0 1px rgba(34,197,94,0.15);
        display: flex; flex-direction: column;
        transform: scale(0.92) translateY(16px); opacity: 0;
        transition: transform 0.25s cubic-bezier(.34,1.56,.64,1), opacity 0.2s;
        pointer-events: none; overflow: hidden;
    }
    #riva-panel.riva-open {
        transform: scale(1) translateY(0); opacity: 1; pointer-events: all;
    }
    #riva-header {
        background: linear-gradient(135deg, #071d0f, #0d3320);
        color: #fff; padding: 0.85rem 1rem;
        display: flex; align-items: center; justify-content: space-between;
    }
    #riva-header-info { display: flex; align-items: center; gap: 0.6rem; }
    #riva-avatar { font-size: 1.6rem; }
    #riva-header-info strong { font-size: 0.97rem; font-weight: 700; display: block; }
    #riva-status { font-size: 0.72rem; opacity: 0.7; }
    #riva-header-actions { display: flex; gap: 0.4rem; }
    #riva-header-actions button {
        background: rgba(255,255,255,0.1); border: none; border-radius: 8px;
        color: #fff; width: 32px; height: 32px; cursor: pointer; font-size: 0.95rem;
        display: flex; align-items: center; justify-content: center; transition: background 0.18s;
    }
    #riva-header-actions button:hover { background: rgba(255,255,255,0.2); }
    #riva-tts-toggle.riva-tts-off { opacity: 0.45; }

    #riva-messages {
        flex: 1; overflow-y: auto; padding: 0.85rem; height: 300px;
        display: flex; flex-direction: column; gap: 0.65rem;
        background: #f8fdf9;
        scrollbar-width: thin; scrollbar-color: #d1fae5 transparent;
    }
    .riva-msg { display: flex; gap: 0.5rem; align-items: flex-end; max-width: 92%; }
    .riva-msg--user { flex-direction: row-reverse; align-self: flex-end; }
    .riva-msg-avatar { font-size: 1.3rem; flex-shrink: 0; margin-bottom: 2px; }
    .riva-msg-bubble {
        background: #fff; border: 1.5px solid #d1fae5;
        border-radius: 16px 16px 16px 4px; padding: 0.6rem 0.85rem;
        font-size: 0.875rem; line-height: 1.55; color: #111827;
        box-shadow: 0 2px 8px rgba(7,29,15,0.06);
    }
    .riva-msg--user .riva-msg-bubble {
        background: linear-gradient(135deg, #22c55e, #16a34a); color: #fff;
        border: none; border-radius: 16px 16px 4px 16px;
        box-shadow: 0 3px 12px rgba(34,197,94,0.3);
    }
    .riva-typing .riva-msg-bubble { display: flex; gap: 4px; align-items: center; padding: 0.7rem 1rem; }
    .riva-dot { width: 7px; height: 7px; background: #22c55e; border-radius: 50%; animation: riva-bounce 1.2s infinite both; }
    .riva-dot:nth-child(2) { animation-delay: 0.18s; }
    .riva-dot:nth-child(3) { animation-delay: 0.36s; }
    @@keyframes riva-bounce { 0%,80%,100%{transform:translateY(0)} 40%{transform:translateY(-7px)} }

    #riva-input-row {
        display: flex; gap: 0.4rem; padding: 0.7rem 0.85rem;
        border-top: 1px solid #e8f5ee; background: #fff;
    }
