    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
    // Sync sidebar + topbar dark mode buttons with current state
    (function(){
        function syncDarkUI() {
            var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            var icon = document.getElementById('sidebarDarkIcon');
            var label = document.getElementById('sidebarDarkLabel');
            var topBtn = document.getElementById('topbarDarkBtn');
            if (icon) icon.textContent = isDark ? '☀️' : '🌙';
            if (label) label.textContent = isDark ? 'Light Mode' : 'Dark Mode';
            if (topBtn) topBtn.textContent = isDark ? '☀️' : '🌙';
        }
        syncDarkUI();
        // Re-sync whenever MakauDark.toggle is called
        var origToggle = typeof MakauDark !== 'undefined' ? MakauDark.toggle : null;
        if (origToggle) {
            MakauDark.toggle = function(){ origToggle(); setTimeout(syncDarkUI, 50); };
        }
        // Also observe attribute changes on <html>
        var obs = new MutationObserver(syncDarkUI);
        obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    @* Post-login agreement gate removed — users now accept Terms & Privacy
       directly on the Login/Register form via the in-form checkbox, so a
       second modal here would be redundant. The mkNeedsAgreement flag is
       kept (computed in the head block) only as a future safeguard if the
       Terms version is bumped. *@

