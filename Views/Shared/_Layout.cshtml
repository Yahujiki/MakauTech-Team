    <!-- ===== YENKAH AI CHAT WIDGET ===== -->
    <div id="riva-fab" class="tut-yenkah-fab" title="Chat with Yenkah — your Sibu AI guide" aria-label="Open AI assistant">
        <span id="riva-fab-icon">🦢</span>
        <span id="riva-fab-pulse"></span>
    </div>

    <div id="riva-panel" role="dialog" aria-label="Yenkah AI tourism assistant" aria-hidden="true">
