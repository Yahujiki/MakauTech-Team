@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject MakauTech.Data.MakauTechDbContext MkDbCtx
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var act = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string NavActive(string c, string a) => ctrl.Equals(c, StringComparison.OrdinalIgnoreCase) && act.Equals(a, StringComparison.OrdinalIgnoreCase) ? "sidebar-link--active" : "";
    // Issue + persist the antiforgery token cookie (HttpOnly, __Host-, SameSite=Strict).
    // The header half is exposed to JS via <meta> below — the cookie half stays HttpOnly.
    var csrfTokens = Antiforgery.GetAndStoreTokens(Context);

    const string mkTermsVersion = "2026-04";
    bool mkShouldShowUiTutorial = false;
    bool mkNeedsAgreement = false;
    var mkUid = Context.Session.GetInt32("UserId");
    if (mkUid.HasValue && Context.Session.GetString("mk-show-tutorial") == "pending")
    {
        var mkUser = MkDbCtx.Users.AsNoTracking().FirstOrDefault(u => u.Id == mkUid.Value);
        mkShouldShowUiTutorial = mkUser != null && !mkUser.UiTutorialSeen;
    }
    if (mkUid.HasValue)
    {
        var mkUser = MkDbCtx.Users.AsNoTracking().FirstOrDefault(u => u.Id == mkUid.Value);
        mkNeedsAgreement = mkUser != null && mkUser.TermsVersionAccepted != mkTermsVersion;
    }
}
