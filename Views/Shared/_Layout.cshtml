<body class="@(ViewBag.IsLoggedIn == true ? "has-sidebar" : "no-sidebar")">
    @* Antiforgery token rendered globally as a fallback for older inline scripts.
       Modern callers should read window.MakauSecurity.getCsrfToken() (sourced from <meta>). *@
    @Html.AntiForgeryToken()

    @* Pre-splash decision: must run BEFORE markup paints to avoid FOUC. *@
    <script>
    (function () {
        try {
            var nav = (performance.getEntriesByType && performance.getEntriesByType('navigation')[0]) || null;
            var navType = nav ? nav.type : (performance.navigation ? ['navigate','reload','back_forward','prerender'][performance.navigation.type] : 'navigate');
            var firstVisit = !sessionStorage.getItem('mk-visited');
            var skipFlag = sessionStorage.getItem('mk-skip-splash') === '1';
            // show splash on first visit OR explicit reload (F5/Ctrl+R)
            // skip on internal link nav (skip flag set on click) + back/forward
            var show = (navType === 'reload') || (firstVisit && navType !== 'back_forward');
            if (skipFlag) { show = false; sessionStorage.removeItem('mk-skip-splash'); }
            if (show) {
                document.documentElement.classList.add('mk-splash-active');
            }
            sessionStorage.setItem('mk-visited', '1');
            window.__mkSplash = show;
        } catch (e) { window.__mkSplash = false; }
    })();
    </script>

    @* Pixel-art F5 splash (rendered inside body but hidden via JS if not needed) *@
    <div id="mk-splash" aria-hidden="true" style="display:none;">
        <div class="mk-splash-stack">
            <img src="~/Images/logo.png" alt="MakauTech" class="mk-splash-brand" />
            <div class="mk-splash-bar-wrap" role="progressbar" aria-valuemin="0" aria-valuemax="100">
                <div class="mk-splash-bar-fill"></div>
                <div class="mk-splash-bar-shine"></div>
            </div>
            <div class="mk-splash-status">
                <span class="mk-splash-label">LOADING</span>
                <span class="mk-splash-pct">0%</span>
            </div>
        </div>
    </div>

    @* Top progress bar — shows on internal link clicks and page navigation. *@
    <div id="mk-progress" aria-hidden="true"></div>
    <script>
    (function () {
        /* ── Pixel splash ───────────────────────────────────────── */
        var splash = document.getElementById('mk-splash');
        if (splash && window.__mkSplash) {
            splash.style.display = 'flex';
            splash.setAttribute('aria-hidden', 'false');
            var fill   = splash.querySelector('.mk-splash-bar-fill');
            var pctEl  = splash.querySelector('.mk-splash-pct');
            var status = splash.querySelector('.mk-splash-status');
            var label  = splash.querySelector('.mk-splash-label');
            var pct = 0;
            // Tween 0 → ~92% over 900ms while page settles
            var iv = setInterval(function () {
                if (pct < 92) {
                    pct += Math.max(2, Math.round((92 - pct) * 0.18));
                    if (pct > 92) pct = 92;
                    fill.style.width = pct + '%';
                    pctEl.textContent = pct + '%';
                }
            }, 60);
            // Snap to 100% + show "COMPLETED!" when window has loaded
            function finish() {
                clearInterval(iv);
                pct = 100;
                fill.style.width = '100%';
                pctEl.textContent = '100%';
                label.textContent = 'COMPLETED!';
                if (status) status.classList.add('is-done');
                setTimeout(function () {
                    splash.classList.add('is-hidden');
                    document.documentElement.classList.remove('mk-splash-active');
                    setTimeout(function () { splash.style.display = 'none'; }, 450);
                }, 420);
            }
            if (document.readyState === 'complete') {
                setTimeout(finish, 600);
            } else {
                window.addEventListener('load', function () { setTimeout(finish, 280); });
            }
        }

        /* ── Top progress bar (link clicks) ─────────────────────── */
        var bar = document.getElementById('mk-progress');
        if (!bar) return;
        var hideTimer = null;

        function start() {
            if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
            bar.classList.remove('is-done');
            void bar.offsetWidth;
            bar.classList.add('is-loading');
        }
        function done() {
            bar.classList.remove('is-loading');
            bar.classList.add('is-done');
            hideTimer = setTimeout(function () { bar.classList.remove('is-done'); }, 600);
        }

        // Internal link click → skip splash next page + show top bar
        document.addEventListener('click', function (e) {
            var a = e.target && e.target.closest ? e.target.closest('a') : null;
            if (!a) return;
            if (a.target === '_blank') return;
            if (a.hasAttribute('download')) return;
            if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
            var href = a.getAttribute('href');
            if (!href || href.startsWith('#') || href.startsWith('javascript:') ||
                href.startsWith('mailto:') || href.startsWith('tel:')) return;
            try {
                var url = new URL(a.href, window.location.origin);
                if (url.origin !== window.location.origin) return;
                if (url.pathname === window.location.pathname && url.search === window.location.search) return;
            } catch (_) { return; }
            try { sessionStorage.setItem('mk-skip-splash', '1'); } catch (_) {}
            start();
        }, true);

        document.addEventListener('submit', function (e) {
            var f = e.target;
            if (!f || f.tagName !== 'FORM') return;
            if (f.target === '_blank') return;
            if (f.hasAttribute('data-ajax') || f.classList.contains('no-progress')) return;
            try { sessionStorage.setItem('mk-skip-splash', '1'); } catch (_) {}
            start();
        }, true);

        window.addEventListener('pageshow', done);
        window.addEventListener('load', done);
        window.addEventListener('beforeunload', start);
    })();
    </script>

