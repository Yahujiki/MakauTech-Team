@{
    ViewData["Title"] = "Sibu Sprint";
    bool firstFree = ViewBag.FirstGameFree == true;
    int cost = ViewBag.PlayCost ?? 20;
    int pts = ViewBag.UserPoints ?? 0;
}

@section Styles {
    <style>
        body {
            background: #030d06 !important;
        }

        .main-content {
            background: #030d06;
        }

        .footer {
            display: none;
        }
    </style>
}

<style>
    .sprint-shell {
        max-width: 560px;
        margin: 2.5rem auto;
        padding: 0 1rem;
    }

    .sprint-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }

        .sprint-header h1 {
            font-size: 2rem;
            font-weight: 800;
            color: #071d0f;
            margin-bottom: 0.4rem;
        }

        .sprint-header p {
            color: #4b5563;
            font-size: 1rem;
        }

    .sprint-tags {
        display: flex;
        justify-content: center;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin: 0.75rem 0;
    }

    .sprint-tag {
        padding: 0.3rem 0.9rem;
        border-radius: 20px;
        font-size: 0.82rem;
        font-weight: 700;
    }

    .sprint-tag--cost {
        background: #fef3c7;
        color: #92400e;
    }

    .sprint-tag--earn {
        background: #dcfce7;
        color: #166534;
    }

    .sprint-tag--free {
        background: #dbeafe;
        color: #1e40af;
    }

    /* Pay screen */
    #sprintPayScreen {
        background: #fff;
        border-radius: 18px;
        padding: 2rem;
        box-shadow: 0 8px 32px rgba(7,29,15,0.12);
        text-align: center;
        border: 1.5px solid rgba(34,197,94,0.12);
    }

    .sprint-pay-icon {
        font-size: 3.5rem;
        margin-bottom: 0.5rem;
    }

    .sprint-pay-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: #071d0f;
        margin-bottom: 0.5rem;
    }

    .sprint-pay-desc {
        color: #4b5563;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
    }

    .sprint-pay-pts {
        font-size: 1.1rem;
        color: #166534;
        font-weight: 700;
        background: #dcfce7;
        padding: 0.5rem 1.25rem;
        border-radius: 999px;
        display: inline-block;
        margin-bottom: 1.25rem;
    }

    .sprint-rules {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .sprint-rule {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 10px;
        padding: 0.6rem 1rem;
        font-size: 0.88rem;
        font-weight: 600;
        color: #166534;
    }

    .sprint-btn {
        display: block;
        width: 100%;
        padding: 0.9rem;
        border: none;
        border-radius: 14px;
        font-size: 1.05rem;
        font-weight: 800;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 0.5rem;
    }

    .sprint-btn--play {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: #fff;
        box-shadow: 0 4px 18px rgba(34,197,94,0.35);
    }

        .sprint-btn--play:hover {
            filter: brightness(1.08);
            transform: translateY(-2px);
        }

    #sprintPayErr {
        color: #c62828;
        font-size: 0.9rem;
        min-height: 1.2rem;
        margin-top: 0.25rem;
    }

    /* Game area */
    #sprintGameArea {
        display: none;
    }

    .sprint-hud {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.6rem 0.5rem;
        font-weight: 700;
        color: #071d0f;
        font-size: 1rem;
        margin-bottom: 0.5rem;
    }

    .sprint-hud-score {
        font-size: 1.15rem;
        color: #166534;
    }

    #sprintCanvas {
        display: block;
        width: 100%;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(7,29,15,0.2);
        cursor: pointer;
    }

    .sprint-hint {
        text-align: center;
        color: #6b7280;
        font-size: 0.88rem;
        margin-top: 0.5rem;
    }

    /* Game over */
    #sprintGameOver {
        display: none;
        background: #fff;
        border-radius: 18px;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 8px 32px rgba(7,29,15,0.12);
    }

    .sprint-result-icon {
        font-size: 3.5rem;
        margin-bottom: 0.5rem;
    }

    .sprint-result-score {
        font-size: 3rem;
        font-weight: 800;
        color: #071d0f;
    }

    .sprint-result-pts {
        font-size: 1.05rem;
        color: #22c55e;
        font-weight: 700;
        margin: 0.5rem 0 1.25rem;
    }

    .sprint-result-btns {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .sprint-result-btn {
        padding: 0.7rem 1.75rem;
        border-radius: 30px;
        font-weight: 700;
        font-size: 0.95rem;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .sprint-result-btn--primary {
        background: linear-gradient(135deg,#22c55e,#16a34a);
        color: #fff;
        box-shadow: 0 4px 14px rgba(34,197,94,0.3);
    }

    .sprint-result-btn--secondary {
        background: #f0fdf4;
        color: #166534;
        border: 2px solid #bbf7d0;
    }

    #sprintPtsEarned {
        background: #f0fdf4;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        margin: 0.5rem 0 1rem;
        font-weight: 700;
        color: #166534;
    }
</style>

<div class="sprint-shell">
    <div class="sprint-header">
        <h1>🏃 Sibu Sprint</h1>
        <p>Run through Sibu, collect Sarawak treats, dodge obstacles.</p>
        <div class="sprint-tags">
            @if (firstFree)
            {
                <span class="sprint-tag sprint-tag--free">✨ First run FREE</span>
            }
            else
            {
                <span class="sprint-tag sprint-tag--cost">💰 @cost pts to play</span>
            }
            <span class="sprint-tag sprint-tag--earn">🏅 Earn up to 50 pts</span>
        </div>
        <div class="game-fun-mini" style="margin-top:12px;"><b>Rhythm:</b> Time jumps slightly early — crates and potholes punish panic taps. Stack treats when the path opens!</div>
    </div>

    <!-- Pay / Launch screen -->
    <div id="sprintPayScreen">
        <div class="sprint-pay-icon">🏃</div>
        <div class="sprint-pay-title">Ready to Sprint?</div>
        <div class="sprint-pay-desc">Tap/click to jump over obstacles. Grab kek lapis for bonus points!</div>
        <div class="sprint-pay-pts">Your points: <span id="sprintPtsDisplay">@pts</span> pts</div>
        <div class="sprint-rules">
            <div class="sprint-rule">⬆️ Tap / Space to jump</div>
            <div class="sprint-rule">🍰 Collect kek lapis</div>
            <div class="sprint-rule">💥 3 lives</div>
            <div class="sprint-rule">🏅 Up to 50 pts reward</div>
        </div>
        <button class="sprint-btn sprint-btn--play" id="btnSprintPlay">
            @(firstFree ? "▶ Play for FREE" : $"▶ Play for {cost} pts")
        </button>
        <div id="sprintPayErr"></div>
    </div>

    <!-- Canvas game area -->
    <div id="sprintGameArea">
        <div class="sprint-hud">
            <span>🏃 Sibu Sprint</span>
            <span class="sprint-hud-score">Score: <span id="sprintScore">0</span></span>
            <span>❤️ <span id="sprintLives">3</span></span>
        </div>
        <canvas id="sprintCanvas" width="520" height="240"></canvas>
        <p class="sprint-hint">Tap canvas or press Space to jump • Double-tap for double jump</p>
    </div>

    <!-- Game over screen -->
    <div id="sprintGameOver">
        <div class="sprint-result-icon" id="sprintResultIcon">🏁</div>
        <div class="sprint-result-score"><span id="sprintFinalScore">0</span></div>
        <div class="sprint-result-pts">metres sprinted</div>
        <div id="sprintPtsEarned" style="display:none;"></div>
        <div class="sprint-result-btns">
            <button class="sprint-result-btn sprint-result-btn--primary" id="btnSprintAgain">🔄 Sprint Again</button>
            <a href="/Home/Leaderboard" class="sprint-result-btn sprint-result-btn--secondary">🏆 Leaderboard</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
(function () {
    // ── DOM refs ──────────────────────────────────────────────────────
    const payScreen   = document.getElementById('sprintPayScreen');
    const gameArea    = document.getElementById('sprintGameArea');
    const gameOver    = document.getElementById('sprintGameOver');
    const canvas      = document.getElementById('sprintCanvas');
    const ctx         = canvas.getContext('2d');
    const scoreEl     = document.getElementById('sprintScore');
    const livesEl     = document.getElementById('sprintLives');
    const finalScoreEl= document.getElementById('sprintFinalScore');
    const ptsEarnedEl = document.getElementById('sprintPtsEarned');
    const ptsDisplay  = document.getElementById('sprintPtsDisplay');

    // ── Pay / launch ──────────────────────────────────────────────────
    document.getElementById('btnSprintPlay').addEventListener('click', async function () {
        const errEl = document.getElementById('sprintPayErr');
        errEl.textContent = '';
        this.disabled = true;
        this.textContent = 'Loading…';
        try {
            const res = await fetch('/Sibusprinter/PayToPlay', { method: 'POST', headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' } });
            const data = await res.json();
            if (!data.success) { errEl.textContent = data.message || 'Error'; this.disabled = false; this.textContent = '▶ Play'; return; }
            if (data.remainingPoints != null) ptsDisplay.textContent = data.remainingPoints;
        } catch { errEl.textContent = 'Connection error.'; this.disabled = false; return; }
        payScreen.style.display = 'none';
        gameArea.style.display  = 'block';
        startGame();
    });

    document.getElementById('btnSprintAgain').addEventListener('click', function () {
        gameOver.style.display = 'none';
        payScreen.style.display = 'block';
        document.getElementById('btnSprintPlay').disabled = false;
        document.getElementById('btnSprintPlay').textContent = '▶ Play for 20 pts';
        document.getElementById('sprintPayErr').textContent = '';
        ptsEarnedEl.style.display = 'none';
    });

    // ── Constants ─────────────────────────────────────────────────────
    const W = canvas.width, H = canvas.height;
    const GROUND = H - 40;
    const GRAVITY = 0.7;
    const JUMP_V = -14;
    const COLORS = { sky: '#e0f2fe', ground: '#166534', groundLine: '#14532d', runner: '#22c55e', runnerDetail: '#071d0f', obstacle: '#dc2626', collectible: '#f59e0b', cloud: '#fff', score: '#071d0f' };
    const TREATS = ['🍰','🫓','🍜','🏮','⭐'];

    // ── Game state ────────────────────────────────────────────────────
    let runner, obstacles, collectibles, particles, clouds;
    let score, lives, speed, frameCount, gameRunning, animId;
    let jumpCount;

    function startGame() {
        runner = { x: 80, y: GROUND, w: 32, h: 48, vy: 0, onGround: true };
        obstacles = [];
        collectibles = [];
        particles = [];
        clouds = [{ x: 100, y: 40, w: 80 }, { x: 320, y: 60, w: 60 }, { x: 490, y: 30, w: 70 }];
        score = 0; lives = 3; speed = 4; frameCount = 0; gameRunning = true; jumpCount = 0;
        scoreEl.textContent = 0; livesEl.textContent = 3;
        cancelAnimationFrame(animId);
        loop();
    }

    function jump() {
        if (!gameRunning) return;
        if (runner.onGround) { runner.vy = JUMP_V; runner.onGround = false; jumpCount = 1; }
        else if (jumpCount < 2) { runner.vy = JUMP_V * 0.85; jumpCount++; }
    }

    // Input
    canvas.addEventListener('click', jump);
    document.addEventListener('keydown', e => { if (e.code === 'Space') { e.preventDefault(); jump(); } });

    // ── Spawning ──────────────────────────────────────────────────────
    function spawnObstacle() {
        const h = 30 + Math.random() * 30;
        obstacles.push({ x: W + 20, y: GROUND - h + 32, w: 22, h });
    }

    function spawnCollectible() {
        const y = GROUND - 60 - Math.random() * 60;
        collectibles.push({ x: W + 20, y, w: 24, h: 24, emoji: TREATS[Math.floor(Math.random() * TREATS.length)], alpha: 1 });
    }

    function spawnParticles(x, y, color) {
        for (let i = 0; i < 8; i++) {
            const angle = (Math.PI * 2 / 8) * i;
            particles.push({ x, y, vx: Math.cos(angle) * 3, vy: Math.sin(angle) * 3, life: 30, color });
        }
    }

    // ── Collision ─────────────────────────────────────────────────────
    function aabb(a, b) {
        return a.x < b.x + b.w && a.x + a.w > b.x && a.y < b.y + b.h && a.y + a.h > b.y;
    }

    // ── Draw helpers ──────────────────────────────────────────────────
    function drawRunner() {
        const r = runner;
        // Body
        ctx.fillStyle = COLORS.runner;
        ctx.beginPath();
        ctx.roundRect(r.x, r.y, r.w, r.h * 0.7, 6);
        ctx.fill();
        // Head
        ctx.fillStyle = '#fde68a';
        ctx.beginPath();
        ctx.arc(r.x + r.w / 2, r.y - 10, 14, 0, Math.PI * 2);
        ctx.fill();
        // Eye
        ctx.fillStyle = COLORS.runnerDetail;
        ctx.beginPath();
        ctx.arc(r.x + r.w / 2 + 5, r.y - 12, 3, 0, Math.PI * 2);
        ctx.fill();
        // Legs (animated)
        const legOff = Math.sin(frameCount * 0.3) * 8;
        ctx.fillStyle = COLORS.runnerDetail;
        ctx.fillRect(r.x + 4, r.y + r.h * 0.65, 10, r.h * 0.35 + legOff);
        ctx.fillRect(r.x + r.w - 14, r.y + r.h * 0.65, 10, r.h * 0.35 - legOff);
    }

    function drawGround() {
        ctx.fillStyle = COLORS.ground;
        ctx.fillRect(0, GROUND + 32, W, H - GROUND - 32);
        ctx.fillStyle = COLORS.groundLine;
        ctx.fillRect(0, GROUND + 30, W, 4);
        // dashed lane markers
        ctx.fillStyle = 'rgba(255,255,255,0.2)';
        const dashOff = (frameCount * speed * 0.5) % 60;
        for (let x = -dashOff; x < W; x += 60) ctx.fillRect(x, GROUND + 46, 35, 3);
    }

    function drawCloud(c) {
        ctx.fillStyle = 'rgba(255,255,255,0.85)';
        ctx.beginPath();
        ctx.ellipse(c.x, c.y, c.w / 2, 18, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.beginPath();
        ctx.ellipse(c.x + 25, c.y - 6, c.w / 2.5, 14, 0, 0, Math.PI * 2);
        ctx.fill();
    }

    // ── Main loop ─────────────────────────────────────────────────────
    function loop() {
        if (!gameRunning) return;
        frameCount++;
        speed = 4 + Math.floor(frameCount / 180) * 0.5;

        // Sky
        ctx.fillStyle = COLORS.sky;
        ctx.fillRect(0, 0, W, H);

        // Clouds
        clouds.forEach(c => { c.x -= 0.5; if (c.x + c.w < 0) c.x = W + c.w; drawCloud(c); });

        // Ground
        drawGround();

        // Score increment
        if (frameCount % 6 === 0) { score++; scoreEl.textContent = score; }

        // Obstacle spawn
        const spawnRate = Math.max(55, 100 - Math.floor(frameCount / 200) * 5);
        if (frameCount % spawnRate === 0) spawnObstacle();

        // Collectible spawn
        if (frameCount % 80 === 40) spawnCollectible();

        // Runner physics
        runner.vy += GRAVITY;
        runner.y += runner.vy;
        if (runner.y >= GROUND) { runner.y = GROUND; runner.vy = 0; runner.onGround = true; jumpCount = 0; }

        drawRunner();

        // Obstacles
        for (let i = obstacles.length - 1; i >= 0; i--) {
            const o = obstacles[i];
            o.x -= speed;
            // Draw cactus-style obstacle
            ctx.fillStyle = COLORS.obstacle;
            ctx.beginPath();
            ctx.roundRect(o.x, o.y, o.w, o.h, 4);
            ctx.fill();
            ctx.fillStyle = '#7f1d1d';
            ctx.fillRect(o.x + 2, o.y + 2, o.w - 4, 6);
            // Collision with slight forgiveness
            const hitbox = { x: runner.x + 4, y: runner.y + 4, w: runner.w - 8, h: runner.h * 0.7 - 4 };
            if (aabb(hitbox, o)) {
                obstacles.splice(i, 1);
                spawnParticles(runner.x + 16, runner.y + 16, '#fca5a5');
                lives--;
                livesEl.textContent = lives;
                if (lives <= 0) { endGame(); return; }
            } else if (o.x + o.w < 0) { obstacles.splice(i, 1); }
        }

        // Collectibles
        for (let i = collectibles.length - 1; i >= 0; i--) {
            const c = collectibles[i];
            c.x -= speed * 0.8;
            ctx.globalAlpha = c.alpha;
            ctx.font = '20px serif';
            ctx.fillText(c.emoji, c.x, c.y);
            ctx.globalAlpha = 1;
            const hitbox = { x: runner.x, y: runner.y, w: runner.w, h: runner.h };
            if (aabb(hitbox, { x: c.x, y: c.y - 20, w: 20, h: 20 })) {
                score += 5; scoreEl.textContent = score;
                spawnParticles(c.x, c.y, '#fde68a');
                collectibles.splice(i, 1);
            } else if (c.x + 24 < 0) collectibles.splice(i, 1);
        }

        // Particles
        for (let i = particles.length - 1; i >= 0; i--) {
            const p = particles[i];
            p.x += p.vx; p.y += p.vy; p.life--;
            ctx.globalAlpha = p.life / 30;
            ctx.fillStyle = p.color;
            ctx.fillRect(p.x - 3, p.y - 3, 6, 6);
            ctx.globalAlpha = 1;
            if (p.life <= 0) particles.splice(i, 1);
        }

        // HUD distance label
        ctx.fillStyle = 'rgba(7,29,15,0.5)';
        ctx.font = '600 13px "Plus Jakarta Sans", sans-serif';
        ctx.fillText('Sibu, Sarawak', 8, 20);

        animId = requestAnimationFrame(loop);
    }

    async function endGame() {
        gameRunning = false;
        cancelAnimationFrame(animId);
        const finalScore = Math.min(score, 500);
        const pts = Math.min(Math.floor(finalScore / 10), 50);

        gameArea.style.display = 'none';
        gameOver.style.display = 'block';
        document.getElementById('sprintResultIcon').textContent = pts >= 40 ? '🏆' : pts >= 20 ? '🏅' : '🏁';
        finalScoreEl.textContent = finalScore + ' m';

        try {
            const res = await fetch('/Sibusprinter/SubmitScore', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ score: pts })
            });
            const data = await res.json();
            if (data.success && data.pointsEarned > 0) {
                ptsEarnedEl.style.display = 'block';
                ptsEarnedEl.textContent = '🏅 +'  + data.pointsEarned + ' pts earned! Total: ' + data.totalPoints + ' pts';
                if (ptsDisplay) ptsDisplay.textContent = data.totalPoints;
            }
        } catch { /* silent */ }
    }

    // Polyfill roundRect for older browsers
    if (!ctx.roundRect) {
        CanvasRenderingContext2D.prototype.roundRect = function(x, y, w, h, r) {
            this.beginPath();
            this.moveTo(x + r, y);
            this.lineTo(x + w - r, y);
            this.quadraticCurveTo(x + w, y, x + w, y + r);
            this.lineTo(x + w, y + h - r);
            this.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
            this.lineTo(x + r, y + h);
            this.quadraticCurveTo(x, y + h, x, y + h - r);
            this.lineTo(x, y + r);
            this.quadraticCurveTo(x, y, x + r, y);
            this.closePath();
        };
    }
})();
    </script>
}
