@model MakauTech.Models.Review
@{
    ViewData["Title"] = "Edit Review";
}
<div class="auth-container">
    <div class="auth-card">
        <h2>Edit Review</h2>
        <form method="post" asp-action="EditReview">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="form-group">
                <label>Rating</label>
                <select name="rating" class="form-control">
                    @for (int i = 5; i >= 1; i--)
                    {
                        <option value="@i" selected="@(Model.Rating == i ? "selected" : null)">@i stars</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Comment</label>
                <textarea name="comment" class="form-control" rows="4" required>@Model.Comment</textarea>
            </div>
            <button type="submit" class="btn-primary btn-full">Save Changes</button>
        </form>
    </div>
</div>